{
  "name": "masterbus",
  "version": "1.0.0",
  "description": "Sistema de gestión de cubiertas Master Bus",
  "main": "api/index.js",
  "scripts": {
    "start": "node api/index.js",
    "dev": "nodemon --ext js,ejs api/index.js",
    "test": "jest --runInBand --forceExit"
