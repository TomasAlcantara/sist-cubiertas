<%
const estadoNombre = (e) => e==1?'Nueva':e==2?'Usada':'Recapada';
const currentPage = 'reportes';
const body = `
<div class="list-head">
  <h2>Reporte por Cubierta</h2>
</div>

<form method="get" action="/reportes/recorrido" class="list-filters">
  <strong>Fuego:</strong>
  <input type="text" name="fuego" value="${fuego}" />
  <button type="submit" class="btn-filter">Buscar</button>
</form>

${cubiertas.length > 0 ? `
<table>
  <thead><th>Fuego</th><th>Modelo</th><th>Medida</th><th>Estado</th><th>Km</th><th>Ubicación</th></thead>
  ${cubiertas.map((c,i)=>`<tr class="${i%2===0?'light':'dark'}">
    <td align="center">${c.fuego||'-'}</td>
    <td align="center">${c.marca||''} ${c.modelo_nombre||''}</td>
    <td align="center">${c.medida||'-'}</td>
    <td align="center">${estadoNombre(c.estado)}</td>
    <td align="center">${c.km||0}</td>
    <td align="center">${c.almacen_nombre||c.gomeria_nombre||c.unidad||'-'}</td>
  </tr>`).join('')}
</table>` : fuego ? '<p style="color:var(--text-muted); margin-top:10px;">Sin resultados para ese fuego.</p>' : ''}

<a href="/reportes" class="list-back">&laquo; Volver</a>
`;
%>
<%- include('../layout', { body, user, currentPage }) %>
