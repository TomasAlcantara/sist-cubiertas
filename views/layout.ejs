<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Master Bus — Sistema de Cubiertas</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800&family=Barlow:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<link href="/css/style.css" rel="stylesheet" />
<link href="/css/tables.css" rel="stylesheet" />
<link rel="icon" type="image/png" href="/images/icon.png" />
<script src="/js/jquery.min.js"></script>
<script src="/js/jquery-ui.min.js"></script>
<script src="/js/functions.js"></script>
<script src="/js/calendar/jquery-ui.js"></script>
<link rel="stylesheet" href="/js/calendar/jquery-ui.css">
<%- typeof extraHead !== 'undefined' ? extraHead : '' %>
</head>
<body>
  <nav class="nav">
    <a href="/" class="nav-brand">
      <img src="/images/masterbus-logo.png" alt="Master Bus" />
      <span class="nav-brand-sub">Sistema de Cubiertas</span>
    </a>
    <div class="nav-sep"></div>
    <% if (typeof user !== 'undefined' && user) { %>
    <ul class="nav-links">
      <li class="<%= currentPage === 'inicio' ? 'active' : '' %>">
        <a href="/">Inicio</a>
      </li>
      <li class="<%= currentPage === 'reportes' ? 'active' : '' %>">
        <a href="/reportes">Reportes</a>
      </li>
      <% if (user.tipo === 1) { %>
      <li class="<%= currentPage === 'admin' ? 'active' : '' %>">
        <a href="/admin">Administrar</a>
      </li>
      <% } %>
      <li class="<%= currentPage === 'manual' ? 'active' : '' %>">
        <a href="/manual">Manual</a>
      </li>
      <li class="nav-logout">
        <a href="/logout">Salir</a>
      </li>
    </ul>
    <% } else { %>
    <ul class="nav-links">
      <li class="nav-logout">
        <a href="/login">Ingresar</a>
      </li>
    </ul>
    <% } %>
  </nav>

  <main class="page-wrap">
    <div class="article">
      <%- body %>
    </div>
  </main>

  <footer class="footer">
    <div class="footer-inner">
      <p>Sistema desarrollado por <strong>Master Bus S.A.</strong></p>
    </div>
  </footer>
</body>
</html>
