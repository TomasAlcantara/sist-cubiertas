<%
const currentPage = 'inicio';
const body = `
<div class="list-head">
  <h2>Recapadoras</h2>
  <a href="/OTs/nueva" class="btn-nuevo">Nueva OT</a>
</div>
<form method="get" action="/recapadoras" class="list-filters">
  <strong>Recapadora:</strong>
  <select name="recapadora">
    <option value="0">Todas</option>
    ${recapadoras.map(r => `<option value="${r.id}" ${r.id==filtros.recapadora?'selected':''}>${r.nombre}</option>`).join('')}
  </select>
  <strong>Estado:</strong>
  <select name="estado">
    <option value="-1" ${filtros.estado==-1?'selected':''}>Todos</option>
    <option value="0"  ${filtros.estado==0?'selected':''}>Abierta</option>
    <option value="1"  ${filtros.estado==1?'selected':''}>Cerrada</option>
  </select>
  <button type="submit" class="btn-filter">Filtrar</button>
</form>

<table>
  <thead>
    <th>OT Número</th>
    <th>Recapadora</th>
    <th>Fecha</th>
    <th>Estado</th>
    <th style="width:100px;">Editar</th>
  </thead>
  ${ots.length === 0 ? '<tr><td colspan="5" align="center">Sin órdenes de trabajo</td></tr>' :
    ots.map((o, i) => `<tr class="${i%2===0?'light':'dark'}">
      <td align="center">${o.numero||o.id}</td>
      <td align="center">${o.recapadora_nombre||'-'}</td>
      <td align="center">${o.fecha ? new Date(o.fecha).toLocaleDateString('es-AR') : '-'}</td>
      <td align="center"><strong>${o.estado==0?'Abierta':'Cerrada'}</strong></td>
      <td align="center"><a href="/OTs/ver?ot=${o.id}">${o.estado==1?'CERRADA':'VER'}</a></td>
    </tr>`).join('')
  }
</table>
`;
%>
<%- include('../layout', { body, user, currentPage }) %>
