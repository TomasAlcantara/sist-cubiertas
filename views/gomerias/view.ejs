<%
const estadoNombre = (e) => e == 1 ? 'Nueva' : e == 2 ? 'Usada' : 'Recapada';
const currentPage = 'inicio';
const body = `
<script>
function orderby(id) {
  var ob = ${filtros.orderby};
  if (id == ob) id += 10;
  location.href = '?id=${gomeria.id}&fuego=${filtros.fuego}&modelo=${filtros.modelo}&estado=${filtros.estado}&orderby=' + id;
}
function show_almacenes(cubierta_id) {
  document.getElementById('back').style.display = '';
  document.getElementById('almacenes').style.display = '';
  document.getElementById('cubierta_id').value = cubierta_id;
}
function close_almacenes() {
  document.getElementById('back').style.display = 'none';
  document.getElementById('almacenes').style.display = 'none';
}
function mover_cubierta(almacen) {
  $.ajax({ type:'POST', url:'/ajax/mover_cubierta', data:{ cubierta: document.getElementById('cubierta_id').value, almacen: almacen }, success: function(){ location.reload(); } });
}
</script>

<div id="back" style="display:none;" onclick="close_almacenes();" class="overlay"></div>
<div id="almacenes" style="width:600px; padding:20px; position:fixed; background:#FFF; z-index:99; display:none; top:100px; left:50%; transform:translateX(-50%);">
  <p><strong>Mover cubierta al almacén:</strong></p>
  <input type="hidden" id="cubierta_id" value="" />
  ${almacenes.map(a => `<input type="button" class="adm_button" value="${a.nombre}" onclick="mover_cubierta(${a.id})" style="margin:3px;"/>`).join('')}
</div>

<h3>${gomeria.nombre}</h3>
<form method="get" action="/gomerias/view">
  <input type="hidden" name="id" value="${gomeria.id}" />
  <strong>Fuego:</strong> <input type="text" name="fuego" value="${filtros.fuego}" maxlength="8" />
  <strong style="margin-left:10px;">Modelo:</strong>
  <select name="modelo">
    <option value="0">Todos</option>
    ${modelos.map(m => `<option value="${m.id}" ${m.id == filtros.modelo ? 'selected' : ''}>${m.marca} ${m.modelo_nombre}</option>`).join('')}
  </select>
  <strong style="margin-left:10px;">Estado:</strong>
  <select name="estado">
    <option value="0">Todos</option>
    <option value="1" ${filtros.estado==1?'selected':''}>Nueva</option>
    <option value="2" ${filtros.estado==2?'selected':''}>Usada</option>
    <option value="3" ${filtros.estado==3?'selected':''}>Recapada</option>
  </select>
  <input type="button" value="Filtrar" onclick="this.form.submit()" style="margin-left:10px; width:75px;" />
</form>
<div class="clr" style="margin-bottom:10px;"></div>
<table>
  <thead>
    <th onclick="orderby(1)" style="cursor:pointer;">Fuego</th>
    <th onclick="orderby(2)" style="cursor:pointer;">Modelo</th>
    <th onclick="orderby(3)" style="cursor:pointer;">Medida</th>
    <th onclick="orderby(4)" style="cursor:pointer;">Estado</th>
    <th onclick="orderby(5)" style="cursor:pointer;">Km</th>
    <th>Mover</th>
  </thead>
  ${cubiertas.length === 0 ? '<tr><td colspan="6" align="center">Sin cubiertas</td></tr>' :
    cubiertas.map((c, i) => `<tr class="${i%2===0?'light':'dark'}">
      <td align="center">${c.fuego||'-'}</td>
      <td align="center">${c.marca||''} ${c.modelo_nombre||''}</td>
      <td align="center">${c.medida||'-'}</td>
      <td align="center">${estadoNombre(c.estado)}</td>
      <td align="center">${c.km||0}</td>
      <td align="center"><a style="cursor:pointer;" onclick="show_almacenes(${c.id})">MOVER</a></td>
    </tr>`).join('')
  }
</table>
<br><a href="/gomerias">&laquo; Volver</a>
`;
%>
<%- include('../layout', { body, user, currentPage }) %>
