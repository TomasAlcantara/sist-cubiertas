<%
const currentPage = 'inicio';
const fmtFecha = (d) => {
  if (!d) return '';
  const dt = new Date(d);
  if (isNaN(dt)) return '';
  const dd = String(dt.getUTCDate()).padStart(2,'0');
  const mm = String(dt.getUTCMonth()+1).padStart(2,'0');
  const yyyy = dt.getUTCFullYear();
  return `${dd}/${mm}/${yyyy}`;
};
const body = `
<form method="post" action="/cubiertas/editar" class="form-card">
  <div class="form-header"><h2>Editar Cubierta</h2></div>
  <input type="hidden" name="id" value="${cubierta.id}" />
  <div class="field">
    <label for="fuego">Fuego *</label>
    <input type="text" name="fuego" id="fuego" class="text" maxlength="20" value="${e(cubierta.fuego||'')}" required />
  </div>
  <div class="field">
    <label for="modelo_id">Modelo</label>
    <select name="modelo_id" id="modelo_id">
      <option value="0">— Sin modelo —</option>
      ${modelos.map(m => '<option value="' + m.id + '"' + (m.id==cubierta.modelo_id?' selected':'') + '>' + m.marca + ' ' + m.modelo + '</option>').join('')}
    </select>
  </div>
  <div class="field">
    <label for="medida_id">Medida</label>
    <select name="medida_id" id="medida_id">
      <option value="0">— Sin medida —</option>
      ${medidas.map(m => '<option value="' + m.id + '"' + (m.id==cubierta.medida_id?' selected':'') + '>' + m.medida + '</option>').join('')}
    </select>
  </div>
  <div class="field">
    <label for="estado">Estado</label>
    <select name="estado" id="estado">
      <option value="1"` + (cubierta.estado==1?' selected':'') + `>Nueva</option>
      <option value="2"` + (cubierta.estado==2?' selected':'') + `>Usada</option>
      <option value="3"` + (cubierta.estado==3?' selected':'') + `>Recapada</option>
    </select>
  </div>
  <div class="field">
    <label for="almacen_id">Almacén</label>
    <select name="almacen_id" id="almacen_id">
      <option value="0">— Sin almacén —</option>
      ${almacenes.map(a => '<option value="' + a.id + '"' + (a.id==cubierta.almacen_id?' selected':'') + '>' + a.nombre + '</option>').join('')}
    </select>
  </div>
  <div class="field-row">
    <div class="field">
      <label for="km">Km actuales</label>
      <input type="number" name="km" id="km" value="${cubierta.km||0}" min="0" />
    </div>
    <div class="field">
      <label for="precio">Precio $</label>
      <input type="number" name="precio" id="precio" step="0.01" min="0" value="${cubierta.precio||''}" />
    </div>
  </div>
  <div class="field">
    <label for="proveedor_id">Proveedor</label>
    <select name="proveedor_id" id="proveedor_id">
      <option value="0">— Sin proveedor —</option>
      ${proveedores.map(p => '<option value="' + p.id + '"' + (p.id==cubierta.proveedor_id?' selected':'') + '>' + p.proveedor + '</option>').join('')}
    </select>
  </div>
  <div class="field-row">
    <div class="field">
      <label for="id_interno">ID Interno</label>
      <input type="text" name="id_interno" id="id_interno" class="text" maxlength="50" value="${e(cubierta.id_interno||'')}" />
    </div>
    <div class="field">
      <label for="remito">Remito</label>
      <input type="text" name="remito" id="remito" class="text" maxlength="50" value="${e(cubierta.remito||'')}" />
    </div>
  </div>
  <div class="field">
    <label for="fecha_remito">Fecha remito</label>
    <input type="text" name="fecha_remito" id="fecha_remito" class="text" placeholder="DD/MM/AAAA" value="${fmtFecha(cubierta.fecha_remito)}" style="max-width:160px;" />
  </div>
  <div class="form-actions">
    <input type="submit" class="btn-primary" value="Guardar" />
    <button type="button" class="btn-ghost" onclick="location.href='/cubiertas'">Cancelar</button>
  </div>
</form>
<script>
$(function() { $('#fecha_remito').datepicker({ dateFormat: 'dd/mm/yy' }); });
</script>
`;
%>
<%- include('../layout', { body, user, currentPage }) %>
