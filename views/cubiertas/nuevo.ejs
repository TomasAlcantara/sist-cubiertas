<%
const currentPage = 'inicio';
const errorMsg = typeof error !== 'undefined' && error ? error : '';
const body = `
${errorMsg ? `<p class="error-msg">${errorMsg}</p>` : ''}
<form method="post" action="/cubiertas/nuevo" class="form-card">
  <div class="form-header"><h2>Nueva Cubierta</h2></div>
  <div class="field-row">
    <div class="field">
      <label for="fuego">Fuego inicial *</label>
      <input type="text" name="fuego" id="fuego" class="text" maxlength="20" required />
    </div>
    <div class="field">
      <label for="cantidad">Cantidad</label>
      <input type="number" name="cantidad" id="cantidad" value="1" min="1" max="200" />
    </div>
  </div>
  <div id="fuego-preview" style="display:none; margin:-8px 0 10px 0; padding:7px 12px; background:#1a1a1a; border-left:3px solid #c0392b; border-radius:0 4px 4px 0; font-family:'IBM Plex Mono',monospace; font-size:12px; line-height:1.8;"></div>
  <div class="field">
    <label for="modelo_id">Modelo</label>
    <select name="modelo_id" id="modelo_id">
      <option value="0">— Sin modelo —</option>
      ${modelos.map(m => '<option value="' + m.id + '">' + m.marca + ' ' + m.modelo + '</option>').join('')}
    </select>
  </div>
  <div class="field">
    <label for="medida_id">Medida</label>
    <select name="medida_id" id="medida_id">
      <option value="0">— Sin medida —</option>
      ${medidas.map(m => '<option value="' + m.id + '">' + m.medida + '</option>').join('')}
    </select>
  </div>
  <div class="field">
    <label for="estado">Estado</label>
    <select name="estado" id="estado">
      <option value="1">Nueva</option>
      <option value="2">Usada</option>
      <option value="3">Recapada</option>
    </select>
  </div>
  <div class="field">
    <label for="almacen_id">Almacén</label>
    <select name="almacen_id" id="almacen_id">
      <option value="0">— Sin almacén —</option>
      ${almacenes.map(a => '<option value="' + a.id + '">' + a.nombre + '</option>').join('')}
    </select>
  </div>
  <div class="field-row">
    <div class="field">
      <label for="km">Km actuales</label>
      <input type="number" name="km" id="km" value="0" min="0" />
    </div>
    <div class="field">
      <label for="precio">Precio $</label>
      <input type="number" name="precio" id="precio" step="0.01" min="0" />
    </div>
  </div>
  <div class="field">
    <label for="proveedor_id">Proveedor</label>
    <select name="proveedor_id" id="proveedor_id">
      <option value="0">— Sin proveedor —</option>
      ${proveedores.map(p => '<option value="' + p.id + '">' + p.proveedor + '</option>').join('')}
    </select>
  </div>
  <div class="field-row">
    <div class="field">
      <label for="id_interno">ID Interno</label>
      <input type="text" name="id_interno" id="id_interno" class="text" maxlength="50" />
    </div>
    <div class="field">
      <label for="remito">Remito</label>
      <input type="text" name="remito" id="remito" class="text" maxlength="50" />
    </div>
  </div>
  <div class="field">
    <label for="fecha_remito">Fecha remito</label>
    <input type="text" name="fecha_remito" id="fecha_remito" class="text" placeholder="DD/MM/AAAA" style="max-width:160px;" />
  </div>
  <div class="form-actions">
    <input type="submit" class="btn-primary" value="Guardar" />
    <button type="button" class="btn-ghost" onclick="location.href='/cubiertas'">Cancelar</button>
  </div>
</form>
<script>
$(function() {
  $('#fecha_remito').datepicker({ dateFormat: 'dd/mm/yy' });

  // Quita caracteres invisibles (zero-width, marcas bidi, controles, BOM) que sobreviven
  // a .trim() y romperían la correlatividad al pegar el número desde otra app.
  var INVISIBLES = new RegExp(
    '[\\u0000-\\u001F\\u007F-\\u009F\\u00AD\\u200B-\\u200F\\u2028\\u2029\\u202A-\\u202E\\u2060\\uFEFF]',
    'g'
  );
  function sanitizeFuego(s) {
    return String(s || '').replace(INVISIBLES, '').trim();
  }

  function nextFuego(base, i) {
    if (i === 0) return base;
    // Usar [0-9] y no la clase \d: este script se sirve dentro de un template
    // literal de Node, y EJS colapsa la barra-d a una simple d al renderizar.
    var m = base.match(/^(.*?)([0-9]+)$/);
    if (m) return m[1] + String(parseInt(m[2]) + i).padStart(m[2].length, '0');
    return base + i;
  }

  function actualizarPreview() {
    var base = sanitizeFuego(document.getElementById('fuego').value);
    var qty  = parseInt(document.getElementById('cantidad').value) || 1;
    var prev = document.getElementById('fuego-preview');
    if (!base || qty < 2) { prev.style.display = 'none'; return; }
    var nums = [];
    for (var i = 0; i < qty; i++) nums.push(nextFuego(base, i));
    prev.style.display = 'block';
    prev.innerHTML = '<span style="color:#888;">Se crearán:</span>  ' +
      nums.map(function(n){ return '<span style="color:#fff;font-weight:600;">' + n + '</span>'; }).join('<span style="color:#c0392b;"> &nbsp;·&nbsp; </span>') +
      '  <span style="color:#666;">(' + qty + ' cubiertas)</span>';
  }

  fetch('/ajax/ultimo_fuego')
    .then(function(r){ return r.json(); })
    .then(function(d){
      var f = document.getElementById('fuego');
      if (f && !f.value) { f.value = d.sugerido; actualizarPreview(); }
    });

  // Al salir del campo, limpiar el valor visible (y el que se enviará) de invisibles.
  document.getElementById('fuego').addEventListener('blur', function() {
    var limpio = sanitizeFuego(this.value);
    if (limpio !== this.value) { this.value = limpio; actualizarPreview(); }
  });

  document.getElementById('fuego').addEventListener('input', actualizarPreview);
  document.getElementById('cantidad').addEventListener('input', actualizarPreview);
});
</script>
`;
%>
<%- include('../layout', { body, user, currentPage }) %>
