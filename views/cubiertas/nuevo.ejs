<%
const currentPage = 'inicio';
const errorMsg = typeof error !== 'undefined' && error ? error : '';
const body = `
${errorMsg ? `<p class="error-msg">${errorMsg}</p>` : ''}
<form method="post" action="/cubiertas/nuevo" class="form-card">
  <div class="form-header"><h2>Nueva Cubierta</h2></div>
  <div class="field-row">
    <div class="field">
      <label for="fuego">Fuego inicial *</label>
      <input type="text" name="fuego" id="fuego" class="text" maxlength="20" required />
    </div>
    <div class="field">
      <label for="cantidad">Cantidad</label>
      <input type="number" name="cantidad" id="cantidad" value="1" min="1" max="200" />
    </div>
  </div>
  <div class="field">
    <label for="modelo_id">Modelo</label>
    <select name="modelo_id" id="modelo_id">
      <option value="0">— Sin modelo —</option>
      ${modelos.map(m => '<option value="' + m.id + '">' + m.marca + ' ' + m.modelo + '</option>').join('')}
    </select>
  </div>
  <div class="field">
    <label for="medida_id">Medida</label>
    <select name="medida_id" id="medida_id">
      <option value="0">— Sin medida —</option>
      ${medidas.map(m => '<option value="' + m.id + '">' + m.medida + '</option>').join('')}
    </select>
  </div>
  <div class="field">
    <label for="estado">Estado</label>
    <select name="estado" id="estado">
      <option value="1">Nueva</option>
      <option value="2">Usada</option>
      <option value="3">Recapada</option>
    </select>
  </div>
  <div class="field">
    <label for="almacen_id">Almacén</label>
    <select name="almacen_id" id="almacen_id">
      <option value="0">— Sin almacén —</option>
      ${almacenes.map(a => '<option value="' + a.id + '">' + a.nombre + '</option>').join('')}
    </select>
  </div>
  <div class="field-row">
    <div class="field">
      <label for="km">Km actuales</label>
      <input type="number" name="km" id="km" value="0" min="0" />
    </div>
    <div class="field">
      <label for="precio">Precio $</label>
      <input type="number" name="precio" id="precio" step="0.01" min="0" />
    </div>
  </div>
  <div class="field">
    <label for="proveedor_id">Proveedor</label>
    <select name="proveedor_id" id="proveedor_id">
      <option value="0">— Sin proveedor —</option>
      ${proveedores.map(p => '<option value="' + p.id + '">' + p.proveedor + '</option>').join('')}
    </select>
  </div>
  <div class="field-row">
    <div class="field">
      <label for="id_interno">ID Interno</label>
      <input type="text" name="id_interno" id="id_interno" class="text" maxlength="50" />
    </div>
    <div class="field">
      <label for="remito">Remito</label>
      <input type="text" name="remito" id="remito" class="text" maxlength="50" />
    </div>
  </div>
  <div class="field">
    <label for="fecha_remito">Fecha remito</label>
    <input type="text" name="fecha_remito" id="fecha_remito" class="text" placeholder="DD/MM/AAAA" style="max-width:160px;" />
  </div>
  <div class="form-actions">
    <input type="submit" class="btn-primary" value="Guardar" />
    <button type="button" class="btn-ghost" onclick="location.href='/cubiertas'">Cancelar</button>
  </div>
</form>
<script>
$(function() { $('#fecha_remito').datepicker({ dateFormat: 'dd/mm/yy' }); });
</script>
`;
%>
<%- include('../layout', { body, user, currentPage }) %>
