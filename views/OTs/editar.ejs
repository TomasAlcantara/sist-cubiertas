<%
const currentPage = 'inicio';
const fechaFormateada = ot.fecha ? new Date(ot.fecha).toLocaleDateString('es-AR') : '';
const cubCargadas = {};
ot_cubiertas.forEach(c => { cubCargadas[c.posicion] = { id: c.cubierta_id, fuego: c.fuego }; });
const cambiosIniciales = {};
ot_cubiertas.forEach(c => { cambiosIniciales[c.posicion] = c.cubierta_id; });
const body = `
<style>
.bus-row { display:flex; align-items:center; justify-content:center; }
.rueda { width:52px; height:68px; background:#111; border:2px solid #444; display:inline-flex; align-items:center; justify-content:center; cursor:pointer; margin:2px; flex-direction:column; }
.rueda:hover { background:#222; border-color:#666; }
.rueda.seleccionada { border-color:#c00; background:#3a0000; }
.rueda .fn { color:#fff; font-size:10px; font-weight:bold; text-align:center; word-break:break-all; line-height:1.2; padding:2px; }
.rueda .fn.vacia { color:#555; font-size:18px; }
.rueda.seleccionada .fn { color:#cc0000; }
.bus-top-bot { background:#fff; border:2px solid #333; width:200px; height:16px; }
.bus-side { background:#fff; border-left:2px solid #333; border-right:2px solid #333; width:200px; }
.bus-axle { background:#ddd; border-left:2px solid #333; border-right:2px solid #333; width:200px; height:24px; }
.bus-spacer { width:56px; }
.aux-row { margin-top:8px; display:flex; align-items:center; justify-content:center; gap:8px; }
.aux-row span { font-size:12px; font-weight:bold; }
</style>

<script>
var cambios_ot = ${JSON.stringify(cambiosIniciales)};
var current_pos = '';

var LAYOUTS = {
  1: { del:['ddi','ddd'], tr1:['tie','tde'],             tr2:[], aux:['ra'],        bodyH:140 },
  2: { del:['ddi','ddd'], tr1:['cie','cii','cdi','cde'], tr2:['tie','tde'], aux:['ra','ra2'], bodyH:80  },
  3: { del:['ddi','ddd'], tr1:['tie','tii','tdi','tde'], tr2:[], aux:['ra','ra2'], bodyH:140 },
  4: { del:['ddi','ddd'], tr1:['tie','tii','tdi','tde'], tr2:[], aux:['ra','ra2'], bodyH:140 }
};

function mkRueda(pos) {
  return '<div class="rueda" id="pos-'+pos+'" onclick="abrir_modal(\\''+pos+'\\')"><span class="fn vacia" id="fn-'+pos+'">+</span></div>';
}

function renderDiagrama(tipo) {
  var L = LAYOUTS[tipo] || LAYOUTS[1];
  var del = L.del, tr1 = L.tr1, tr2 = L.tr2;
  var midD = Math.ceil(del.length/2), midT = Math.ceil(tr1.length/2);
  var h = '';
  h += '<div class="bus-row">';
  del.slice(0,midD).forEach(function(p){ h += mkRueda(p); });
  h += '<div class="bus-spacer"></div><div style="width:200px;"></div><div class="bus-spacer"></div>';
  del.slice(midD).forEach(function(p){ h += mkRueda(p); });
  h += '</div>';
  h += '<div class="bus-row"><div class="bus-spacer"></div><div class="bus-top-bot"></div><div class="bus-spacer"></div></div>';
  h += '<div class="bus-row"><div class="bus-spacer"></div><div class="bus-side" style="height:'+L.bodyH+'px;"></div><div class="bus-spacer"></div></div>';
  h += '<div class="bus-row"><div class="bus-spacer"></div><div class="bus-top-bot"></div><div class="bus-spacer"></div></div>';
  h += '<div class="bus-row">';
  tr1.slice(0,midT).forEach(function(p){ h += mkRueda(p); });
  h += '<div class="bus-axle"></div>';
  tr1.slice(midT).forEach(function(p){ h += mkRueda(p); });
  h += '</div>';
  if (tr2.length) {
    var midT2 = Math.ceil(tr2.length/2);
    h += '<div class="bus-row">';
    tr2.slice(0,midT2).forEach(function(p){ h += mkRueda(p); });
    h += '<div class="bus-axle"></div>';
    tr2.slice(midT2).forEach(function(p){ h += mkRueda(p); });
    h += '</div>';
  }
  var auxList = L.aux || ['ra'];
  h += '<div class="aux-row"><span>Auxilio</span>'+auxList.map(function(p){ return mkRueda(p); }).join('')+'</div>';
  document.getElementById('diagrama-wrap').innerHTML = h;
}

function cargar_tires(unidad_id) {
  if (!unidad_id) {
    document.getElementById('diagrama-wrap').innerHTML = '<p style="color:var(--text-muted); font-size:12px; text-align:center;">Seleccione una unidad para ver el diagrama</p>';
    return;
  }
  $.ajax({ type:'GET', url:'/ajax/cubiertas_unidad?unidad_id='+unidad_id,
    success: function(data) {
      var tipo = data.tipo_unidad || 1;
      renderDiagrama(tipo);
      (data.cubiertas || []).forEach(function(c) {
        var el = document.getElementById('fn-'+c.posicion);
        if (el) { el.innerHTML = c.fuego || '-'; el.classList.remove('vacia'); }
      });
      var cargadas = ${JSON.stringify(cubCargadas)};
      Object.keys(cargadas).forEach(function(pos) {
        var el = document.getElementById('fn-'+pos);
        var p  = document.getElementById('pos-'+pos);
        if (el) { el.innerHTML = cargadas[pos].fuego || '-'; el.classList.remove('vacia'); }
        if (p)  { p.classList.add('seleccionada'); }
      });
    }
  });
}

function abrir_modal(pos) {
  current_pos = pos;
  document.getElementById('back').style.display = 'block';
  document.getElementById('filter_list').style.display = 'block';
  document.getElementById('rueda_list').innerHTML = '';
  filtrar_ot();
}

function cerrar_modal() {
  document.getElementById('back').style.display = 'none';
  document.getElementById('filter_list').style.display = 'none';
}

function filtrar_ot() {
  $.ajax({ type:'POST', url:'/ajax/listar_ruedas',
    data: { almacen:document.getElementById('f_almacen').value, fuego:document.getElementById('f_fuego').value,
            modelo:document.getElementById('f_modelo').value, medida:document.getElementById('f_medida').value,
            estado:document.getElementById('f_estado').value, modo:'ot' },
    success: function(data) { document.getElementById('rueda_list').innerHTML = data; }
  });
}

function seleccionar_ot(id, fuego) {
  cambios_ot[current_pos] = id;
  var el = document.getElementById('fn-'+current_pos);
  if (el) { el.innerHTML = fuego || id; el.classList.remove('vacia'); }
  var p = document.getElementById('pos-'+current_pos);
  if (p) p.classList.add('seleccionada');
  cerrar_modal();
}

function guardar_ot() {
  var unidad_id  = document.getElementById('unidad_id').value;
  var gomeria_id = document.getElementById('gomeria_id').value;
  var fecha      = document.getElementById('fecha').value;
  if (!unidad_id) { alert('Seleccione una unidad'); return; }
  if (!fecha)     { alert('Ingrese la fecha de solicitud'); return; }
  $.ajax({ type:'POST', url:'/ajax/actualizar_ot',
    data: { ot_id: ${ot.id}, unidad_id, gomeria_id, fecha,
            observaciones: document.getElementById('observaciones').value,
            rotacion:  document.getElementById('cb_rotacion').checked  ? '1':'0',
            arreglo:   document.getElementById('cb_arreglo').checked   ? '1':'0',
            cambio:    document.getElementById('cb_cambio').checked    ? '1':'0',
            alinear:   document.getElementById('cb_alinear').checked   ? '1':'0',
            balanceo:  document.getElementById('cb_balanceo').checked  ? '1':'0',
            armar:     document.getElementById('cb_armar').checked     ? '1':'0',
            cambios_ot_json: JSON.stringify(cambios_ot) },
    success: function(id) {
      if (id) location.href = '/OTs/ver?ot='+id;
      else alert('Error al guardar la OT');
    },
    error: function(xhr) { alert('Error del servidor: ' + xhr.status + ' ' + xhr.responseText); }
  });
}

$(function() {
  $('#fecha').datepicker({ dateFormat: 'dd/mm/yy' });
  cargar_tires(document.getElementById('unidad_id').value);
});
</script>

<div class="modal-overlay" id="back" onclick="cerrar_modal();"></div>
<div class="modal-panel" id="filter_list" style="width:600px; max-height:560px; padding:0;">
  <button class="modal-close" onclick="cerrar_modal();">&times;</button>
  <form onsubmit="return false;" class="list-filters" style="padding:12px 14px 8px;">
    <strong>Almacén:</strong>
    <select id="f_almacen">
      <option value="0">Todos</option>
      ${almacenes.map(a => `<option value="${a.id}">${a.nombre}</option>`).join('')}
    </select>
    <strong>Fuego:</strong>
    <input type="text" id="f_fuego" style="width:80px;" />
    <strong>Modelo:</strong>
    <select id="f_modelo">
      <option value="0">Todos</option>
      ${modelos.map(m => `<option value="${m.id}">${m.marca} ${m.modelo}</option>`).join('')}
    </select>
    <strong>Medida:</strong>
    <select id="f_medida">
      <option value="0">Todas</option>
      ${medidas.map(m => `<option value="${m.id}">${m.medida}</option>`).join('')}
    </select>
    <strong>Estado:</strong>
    <select id="f_estado">
      <option value="0">Todos</option>
      <option value="1">Nueva</option>
      <option value="2">Usada</option>
      <option value="3">Recapada</option>
    </select>
    <button type="button" class="btn-filter" onclick="filtrar_ot()">Filtrar</button>
  </form>
  <div id="rueda_list" style="padding:0 14px 14px;"></div>
</div>

<div class="list-head">
  <h2>Editar OT N° ${ot.numero || ot.id}</h2>
  <button class="btn-ghost" onclick="window.print()">Imprimir</button>
</div>

<div class="form-card">
  <div class="field">
    <label for="unidad_id">Unidad</label>
    <select id="unidad_id" onchange="cargar_tires(this.value)">
      <option value="">Seleccione...</option>
      ${unidades.map(u => `<option value="${u.id}" ${u.id==ot.unidad_id?'selected':''}>${u.unidad}</option>`).join('')}
    </select>
  </div>
  <div class="field">
    <label for="gomeria_id">Gomería</label>
    <select id="gomeria_id">
      <option value="">Seleccione...</option>
      ${gomerias.map(g => `<option value="${g.id}" ${g.id==ot.gomeria_id?'selected':''}>${g.nombre}</option>`).join('')}
    </select>
  </div>
  <div class="field">
    <label for="fecha">Fecha de solicitud</label>
    <input type="text" id="fecha" class="text" value="${fechaFormateada}" placeholder="DD/MM/AAAA" style="max-width:160px;" />
  </div>

  <div class="form-section">
    <div class="form-section-title">Trabajo a realizar</div>
    <div class="form-check-grid">
      <label><input type="checkbox" id="cb_rotacion" ${ot.rotacion?'checked':''} /> Rotación</label>
      <label><input type="checkbox" id="cb_arreglo"  ${ot.arreglo ?'checked':''} /> Arreglo</label>
      <label><input type="checkbox" id="cb_cambio"   ${ot.cambio  ?'checked':''} /> Cambio</label>
      <label><input type="checkbox" id="cb_alinear"  ${ot.alinear ?'checked':''} /> Alinear</label>
      <label><input type="checkbox" id="cb_balanceo" ${ot.balanceo?'checked':''} /> Balanceo</label>
      <label><input type="checkbox" id="cb_armar"    ${ot.armar   ?'checked':''} /> Armar</label>
    </div>
  </div>

  <div class="form-section">
    <div class="form-section-title">Observaciones</div>
    <textarea id="observaciones" style="width:100%; height:70px; resize:vertical;">${ot.observaciones||''}</textarea>
  </div>

  <div class="form-section">
    <div class="form-section-title">Cambio de cubiertas — clic en posición para cambiar</div>
    <div id="diagrama-wrap" style="text-align:center; padding:10px 0;">
      <p style="color:var(--text-muted); font-size:12px;">Cargando...</p>
    </div>
  </div>

  <div class="form-actions">
    <button class="btn-primary" onclick="guardar_ot()">Guardar</button>
    <button class="btn-ghost"   onclick="location.href='/OTs/list'">Cancelar</button>
  </div>
</div>
`;
%>
<%- include('../layout', { body, user, currentPage }) %>
