<%
const currentPage = 'inicio';
const trabajosTooltip = (o) => {
  const items = [
    ['Rotación', o.rotacion],
    ['Arreglo',  o.arreglo],
    ['Cambio',   o.cambio],
    ['Alinear',  o.alinear],
    ['Balanceo', o.balanceo],
    ['Armar',    o.armar],
  ];
  const filas = items.map(([n, v]) =>
    '<tr><td>' + n + ':</td><td style="padding-left:6px; color:' + (v ? '#090' : '#c00') + '; font-weight:bold;">' + (v ? 'SI' : 'NO') + '</td></tr>'
  ).join('');
  return '<span class="trab-wrap">Ver Trabajos'
    + '<span class="trab-tip"><table style="border-collapse:collapse; font-size:12px;">' + filas + '</table></span>'
    + '</span>';
};
const body = `
<style>
.trab-wrap { position:relative; cursor:default; color:#621b1d; font-weight:bold; white-space:nowrap; }
.trab-tip { display:none; position:absolute; left:0; top:100%; background:#fff; border:1px solid #aaa; padding:6px 10px; z-index:50; box-shadow:2px 2px 6px rgba(0,0,0,0.2); white-space:nowrap; }
.trab-wrap:hover .trab-tip { display:block; }
</style>
<script>
function open_carga(id) {
  $.ajax({ type:'POST', url:'/ajax/mb_cerrar_ot', data:{ ot_id: id },
    success: function(data) {
      if (data) {
        document.getElementById('cerrar_ot').innerHTML = data;
        document.getElementById('back').style.display = '';
        document.getElementById('cerrar_ot').style.display = '';
      }
    }
  });
}
function close_carga() {
  document.getElementById('back').style.display = 'none';
  document.getElementById('cerrar_ot').style.display = 'none';
}
function confirmar_cerrar(ot_id) {
  var km = document.getElementById('km_cierre').value;
  if (!km) { alert('Ingrese los km actuales'); return; }
  $.ajax({ type:'POST', url:'/ajax/confirmar_cerrar_ot',
    data: {
      ot_id: ot_id,
      km_actual: km,
      factura: document.getElementById('factura_cierre').value,
      costo: document.getElementById('costo_cierre').value
    },
    success: function(data) {
      if (data === 'ok') location.reload();
      else alert('Error al cerrar la OT');
    }
  });
}
</script>

<div id="back" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.4); z-index:98;" onclick="close_carga();"></div>
<div id="cerrar_ot" style="width:700px; height:530px; position:fixed; background:#FFF; z-index:99; display:none; top:80px; left:50%; transform:translateX(-50%);"></div>

<form method="get" action="/OTs/list" style="float:left">
  <strong>Unidad:</strong>
  <select name="unidad">
    <option value="0">Todas</option>
    ${unidades.map(u => `<option value="${u.id}" ${u.id==filtros.unidad?'selected':''}>${u.unidad}</option>`).join('')}
  </select>
  <strong style="margin-left:10px;">Gomería:</strong>
  <select name="gomeria">
    <option value="0">Todas</option>
    ${gomerias.map(g => `<option value="${g.id}" ${g.id==filtros.gomeria?'selected':''}>${g.nombre}</option>`).join('')}
  </select>
  <strong style="margin-left:10px;">Estado:</strong>
  <select name="estado">
    <option value="-1" ${filtros.estado==-1?'selected':''}>Todos</option>
    <option value="0" ${filtros.estado==0?'selected':''}>Pendiente</option>
    <option value="1" ${filtros.estado==1?'selected':''}>Cerrada</option>
  </select>
  <input type="button" value="Filtrar" onclick="this.form.submit()" style="margin-left:20px; width:75px;" />
</form>
<input type="button" value="Nueva OT" style="float:right; width:100px;" onclick="location.href='/OTs/nueva'">
<div style="clear:both; margin-bottom:20px;"></div>

<table>
  <thead>
    <th>OT N°</th>
    <th>Micro</th>
    <th>Gomería</th>
    <th>Fecha</th>
    <th>Solicitó</th>
    <th>Trabajos</th>
    <th>Estado</th>
    <th style="width:160px;">Editar</th>
  </thead>
  ${ots.length === 0 ? '<tr><td colspan="8" align="center">Sin órdenes de trabajo</td></tr>' :
    ots.map((o, i) => `<tr class="${i%2===0?'light':'dark'}">
      <td align="center">${o.numero || o.id}</td>
      <td align="center">${o.unidad||'-'}</td>
      <td align="center">${o.gomeria_nombre||'-'}</td>
      <td align="center">${o.fecha ? new Date(o.fecha).toLocaleDateString('es-AR') : '-'}</td>
      <td align="center">${o.solicitado_por||'-'}</td>
      <td>${trabajosTooltip(o)}</td>
      <td align="center"><strong>${o.estado==0?'Pendiente':'Cerrada'}</strong></td>
      <td align="center">
        ${o.estado==0
          ? '<a href="/OTs/editar?ot='+o.id+'">EDITAR</a> | <a href="/OTs/cargar?ot='+o.id+'">CARGAR</a> | <a style="cursor:pointer;" onclick="open_carga('+o.id+')">CERRAR</a>'
          : '<a href="/OTs/ver?ot='+o.id+'">VER</a>'}
      </td>
    </tr>`).join('')
  }
</table>
`;
%>
<%- include('../layout', { body, user, currentPage }) %>
