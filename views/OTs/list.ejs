<%
const currentPage = 'inicio';
const trabajosTooltip = (o) => {
  const items = [
    ['Rotación', o.rotacion],
    ['Arreglo',  o.arreglo],
    ['Cambio',   o.cambio],
    ['Alinear',  o.alinear],
    ['Balanceo', o.balanceo],
    ['Armar',    o.armar],
  ];
  const filas = items.map(([n, v]) =>
    '<tr><td style="color:var(--text-secondary)">' + n + ':</td><td style="padding-left:6px; color:' + (v ? '#2e7d32' : 'var(--red-bright)') + '; font-weight:bold;">' + (v ? 'SI' : 'NO') + '</td></tr>'
  ).join('');
  return '<span class="trab-wrap">Ver Trabajos'
    + '<span class="trab-tip"><table style="border-collapse:collapse; font-size:12px;">' + filas + '</table></span>'
    + '</span>';
};
const body = `
<style>
.trab-wrap { cursor:default; color:var(--red); font-weight:bold; white-space:nowrap; }
.trab-tip { display:none; position:fixed; background:var(--bg-card); border:1px solid var(--border-strong); padding:6px 10px; z-index:9999; box-shadow:var(--shadow-sm); white-space:nowrap; border-radius:var(--radius); pointer-events:none; }

.ot-filters {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
  margin-bottom: 1.25rem;
}
.ot-filters strong {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-muted);
  white-space: nowrap;
}
.ot-filters select { width: auto; }
.ot-filters-submit {
  background: var(--bg-surface);
  color: var(--text-primary);
  border: 1px solid var(--border-strong);
  font-family: var(--font-display);
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.09em;
  text-transform: uppercase;
  padding: 8px 18px;
  border-radius: var(--radius);
  cursor: pointer;
  transition: background 0.12s;
}
.ot-filters-submit:hover { background: var(--bg-hover); }
.ot-nueva {
  margin-left: auto;
  background: var(--red);
  color: #fff;
  border: none;
  font-family: var(--font-display);
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.09em;
  text-transform: uppercase;
  padding: 8px 20px;
  border-radius: var(--radius);
  cursor: pointer;
  transition: background 0.12s;
  white-space: nowrap;
}
.ot-nueva:hover { background: var(--red-bright); }

.ot-modal {
  width: 720px;
  max-height: 90vh;
  overflow-y: auto;
  position: fixed;
  background: var(--bg-card);
  z-index: 99;
  display: none;
  top: 60px;
  left: 50%;
  transform: translateX(-50%);
  border: 1px solid var(--border-strong);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow);
}
.ot-overlay {
  display: none;
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: rgba(0,0,0,0.4);
  z-index: 98;
}
</style>
<script>
// Tooltip de trabajos — position:fixed para evitar clipping en tabla
document.addEventListener('DOMContentLoaded', function() {
  document.querySelectorAll('.trab-wrap').forEach(function(wrap) {
    var tip = wrap.querySelector('.trab-tip');
    wrap.addEventListener('mouseenter', function() {
      var r = wrap.getBoundingClientRect();
      tip.style.display = 'block';
      var left = r.right + 10;
      var top  = r.top + r.height / 2 - tip.offsetHeight / 2;
      // si se sale por la derecha, mostrar a la izquierda
      if (left + tip.offsetWidth > window.innerWidth - 10) left = r.left - tip.offsetWidth - 10;
      // si se sale por arriba o abajo, ajustar
      top = Math.max(8, Math.min(top, window.innerHeight - tip.offsetHeight - 8));
      tip.style.left = left + 'px';
      tip.style.top  = top  + 'px';
    });
    wrap.addEventListener('mouseleave', function() {
      tip.style.display = 'none';
    });
  });
});

function open_carga(id) {
  $.ajax({ type:'POST', url:'/ajax/mb_cerrar_ot', data:{ ot_id: id },
    success: function(data) {
      if (data) {
        document.getElementById('cerrar_ot').innerHTML = data;
        document.getElementById('back').style.display = 'block';
        document.getElementById('cerrar_ot').style.display = 'block';
      }
    },
    error: function() {
      alert('Error al cargar el formulario de cierre');
    }
  });
}
function close_carga() {
  document.getElementById('back').style.display = 'none';
  document.getElementById('cerrar_ot').style.display = 'none';
}
function confirmar_cerrar(ot_id) {
  var km = document.getElementById('km_cierre').value;
  if (!km) { alert('Ingrese los km actuales'); return; }
  $.ajax({ type:'POST', url:'/ajax/confirmar_cerrar_ot',
    data: {
      ot_id: ot_id,
      km_actual: km,
      factura: document.getElementById('factura_cierre').value,
      costo:   document.getElementById('costo_cierre').value,
      rotacion: document.getElementById('cb_rot_cierre').checked ? '1':'0',
      arreglo:  document.getElementById('cb_arr_cierre').checked ? '1':'0',
      cambio:   document.getElementById('cb_cam_cierre').checked ? '1':'0',
      alinear:  document.getElementById('cb_ali_cierre').checked ? '1':'0',
      balanceo: document.getElementById('cb_bal_cierre').checked ? '1':'0',
      armar:    document.getElementById('cb_arm_cierre').checked ? '1':'0'
    },
    success: function(data) {
      if (data === 'ok') location.reload();
      else alert('Error al cerrar la OT');
    }
  });
}
</script>

<div class="ot-overlay" id="back" onclick="close_carga();"></div>
<div class="ot-modal" id="cerrar_ot"></div>

<form method="get" action="/OTs/list" class="ot-filters">
  <strong>Unidad:</strong>
  <select name="unidad">
    <option value="0">Todas</option>
    ${unidades.map(u => `<option value="${u.id}" ${u.id==filtros.unidad?'selected':''}>${u.unidad}</option>`).join('')}
  </select>
  <strong>Gomería:</strong>
  <select name="gomeria">
    <option value="0">Todas</option>
    ${gomerias.map(g => `<option value="${g.id}" ${g.id==filtros.gomeria?'selected':''}>${g.nombre}</option>`).join('')}
  </select>
  <strong>Estado:</strong>
  <select name="estado">
    <option value="-1" ${filtros.estado==-1?'selected':''}>Todos</option>
    <option value="0" ${filtros.estado==0?'selected':''}>Pendiente</option>
    <option value="1" ${filtros.estado==1?'selected':''}>Cerrada</option>
  </select>
  <button type="submit" class="ot-filters-submit">Filtrar</button>
  <button type="button" class="ot-nueva" onclick="location.href='/OTs/nueva'">Nueva OT</button>
</form>

<table>
  <thead>
    <th>OT N°</th>
    <th>Micro</th>
    <th>Gomería</th>
    <th>Fecha</th>
    <th>Solicitó</th>
    <th>Trabajos</th>
    <th>Estado</th>
    <th style="width:160px;">Editar</th>
  </thead>
  ${ots.length === 0 ? '<tr><td colspan="8" align="center">Sin órdenes de trabajo</td></tr>' :
    ots.map((o, i) => `<tr class="${i%2===0?'light':'dark'}">
      <td align="center">${o.numero || o.id}</td>
      <td align="center">${o.unidad||'-'}</td>
      <td align="center">${o.gomeria_nombre||'-'}</td>
      <td align="center">${o.fecha ? new Date(o.fecha).toLocaleDateString('es-AR') : '-'}</td>
      <td align="center">${o.solicitado_por||'-'}</td>
      <td>${trabajosTooltip(o)}</td>
      <td align="center"><strong>${o.estado==0?'Pendiente':'Cerrada'}</strong></td>
      <td align="center">
        ${o.estado==0
          ? '<a href="/OTs/editar?ot='+o.id+'">EDITAR</a> | <a href="/OTs/cargar?ot='+o.id+'">CARGAR</a> | <a style="cursor:pointer;" onclick="open_carga('+o.id+')">CERRAR</a>'
          : '<a href="/OTs/ver?ot='+o.id+'">VER</a>'}
      </td>
    </tr>`).join('')
  }
</table>
`;
%>
<%- include('../layout', { body, user, currentPage }) %>
