<%
const currentPage = 'inicio';
const hoy = new Date().toLocaleDateString('es-AR');
const body = `
<style>
#back { display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:98; }
#filter_list { display:none; width:600px; padding:10px; position:fixed; background:#FFF; z-index:99; top:60px; left:50%; transform:translateX(-50%); overflow:auto; max-height:560px; border:1px solid #aaa; box-shadow:2px 2px 8px rgba(0,0,0,0.3); }
#rueda_list table { width:100%; border-collapse:collapse; }
#rueda_list td, #rueda_list th { padding:3px 6px; border:1px solid #ddd; font-size:12px; }
.bus-row { display:flex; align-items:center; justify-content:center; }
.rueda {
  width:72px; height:100px; background:#111; border:2px solid #444;
  display:inline-flex; align-items:stretch; cursor:grab; margin:2px;
  flex-direction:column; overflow:hidden;
}
.rueda:active { cursor:grabbing; }
.rueda:hover { filter:brightness(1.15); }
.rueda.dragging { opacity:0.3; border-style:dashed; }
.rueda.drag-over { box-shadow:0 0 0 2px #fff; filter:brightness(1.3); }
.rueda-out {
  flex:1; display:flex; align-items:center; justify-content:center;
  border-bottom:1px solid #000;
  font-family:'IBM Plex Mono',monospace; font-size:15px; font-weight:700;
  font-variant-numeric:slashed-zero; text-align:center; word-break:break-all;
  line-height:1.2; padding:4px;
  background:#7a1010; color:#fff;
}
.rueda-out.vacia { background:#222; color:#333; font-size:22px; }
.rueda-in {
  flex:1; display:flex; align-items:center; justify-content:center;
  font-family:'IBM Plex Mono',monospace; font-size:14px; font-weight:700;
  font-variant-numeric:slashed-zero; text-align:center; word-break:break-all;
  line-height:1.2; padding:4px;
  background:#1a1a1a; color:#444;
}
.rueda-in.con-valor { background:#1a3a8a; color:#fff; }
.bus-top-bot { background:#fff; border:2px solid #333; width:200px; height:16px; }
.bus-side { background:#fff; border-left:2px solid #333; border-right:2px solid #333; width:200px; }
.bus-axle { background:#ddd; border-left:2px solid #333; border-right:2px solid #333; width:200px; height:24px; }
.bus-spacer { width:76px; }
.aux-row { margin-top:8px; display:flex; align-items:center; justify-content:center; gap:8px; }
.aux-row span { font-size:12px; font-weight:bold; }
</style>

<script>
var cambios_ot = {};
var current_pos = '';
var unidadActual = {};

var LAYOUTS = {
  1: { del:['ddi','ddd'], tr1:['tie','tde'],             tr2:[], aux:['ra'],        bodyH:140 },
  2: { del:['ddi','ddd'], tr1:['cie','cii','cdi','cde'], tr2:['tie','tde'], aux:['ra','ra2'], bodyH:80 },
  3: { del:['ddi','ddd'], tr1:['tie','tii','tdi','tde'], tr2:[], aux:['ra','ra2'], bodyH:140 },
  4: { del:['ddi','ddd'], tr1:['tie','tii','tdi','tde'], tr2:[], aux:['ra','ra2'], bodyH:140 }
};

function mkRueda(pos) {
  var curr = unidadActual[pos];
  var outTxt = curr ? (curr.fuego || '-') : '·';
  var outCls = curr ? 'rueda-out' : 'rueda-out vacia';
  return '<div class="rueda" id="pos-'+pos+'" draggable="true" '+
    'onclick="abrir_modal(\\''+pos+'\\');" '+
    'ondragstart="dStart(event,\\''+pos+'\\');" '+
    'ondragend="dEnd(\\''+pos+'\\');" '+
    'ondragover="dOver(event);" '+
    'ondragenter="dEnter(\\''+pos+'\\');" '+
    'ondragleave="dLeave(\\''+pos+'\\');" '+
    'ondrop="dDrop(event,\\''+pos+'\\');">'+
    '<span class="'+outCls+'" id="fn-out-'+pos+'">'+outTxt+'</span>'+
    '<span class="rueda-in" id="fn-in-'+pos+'">+</span>'+
    '</div>';
}

function renderDiagrama(tipo) {
  var L = LAYOUTS[tipo] || LAYOUTS[1];
  var del  = L.del,  tr1 = L.tr1, tr2 = L.tr2;
  var midD = Math.ceil(del.length/2);
  var midT = Math.ceil(tr1.length/2);

  var h = '';
  h += '<div class="bus-row">';
  del.slice(0,midD).forEach(function(p){ h += mkRueda(p); });
  h += '<div class="bus-spacer"></div><div style="width:200px;"></div><div class="bus-spacer"></div>';
  del.slice(midD).forEach(function(p){ h += mkRueda(p); });
  h += '</div>';
  h += '<div class="bus-row"><div class="bus-spacer"></div><div class="bus-top-bot"></div><div class="bus-spacer"></div></div>';
  h += '<div class="bus-row"><div class="bus-spacer"></div><div class="bus-side" style="height:'+L.bodyH+'px;"></div><div class="bus-spacer"></div></div>';
  h += '<div class="bus-row"><div class="bus-spacer"></div><div class="bus-top-bot"></div><div class="bus-spacer"></div></div>';
  h += '<div class="bus-row">';
  tr1.slice(0,midT).forEach(function(p){ h += mkRueda(p); });
  h += '<div class="bus-axle"></div>';
  tr1.slice(midT).forEach(function(p){ h += mkRueda(p); });
  h += '</div>';
  if (tr2.length) {
    var midT2 = Math.ceil(tr2.length/2);
    h += '<div class="bus-row">';
    tr2.slice(0,midT2).forEach(function(p){ h += mkRueda(p); });
    h += '<div class="bus-axle"></div>';
    tr2.slice(midT2).forEach(function(p){ h += mkRueda(p); });
    h += '</div>';
  }
  var auxList = L.aux || ['ra','ra2'];
  h += '<div class="aux-row"><span>Auxilio</span>' + auxList.map(function(p){ return mkRueda(p); }).join('') + '</div>';
  document.getElementById('diagrama-wrap').innerHTML = h;
}

function cargar_tires(unidad_id) {
  if (!unidad_id) {
    document.getElementById('diagrama-wrap').innerHTML = '<p style="color:#999;font-size:12px;text-align:center;">Seleccione una unidad para ver el diagrama</p>';
    unidadActual = {};
    cambios_ot = {};
    return;
  }
  $.ajax({ type:'GET', url:'/ajax/cubiertas_unidad?unidad_id='+unidad_id,
    success: function(data) {
      var tipo = data.tipo_unidad || 1;
      unidadActual = {};
      (data.cubiertas || []).forEach(function(c) {
        unidadActual[c.posicion] = { id: c.id, fuego: c.fuego };
      });
      renderDiagrama(tipo);
      cambios_ot = {};
    }
  });
}

function clearPos(pos) {
  delete cambios_ot[pos];
  var elIn = document.getElementById('fn-in-'+pos);
  var pEl  = document.getElementById('pos-'+pos);
  if (elIn) { elIn.innerHTML = '+'; elIn.classList.remove('con-valor'); }
  if (pEl)  pEl.classList.remove('con-entrante');
}

function abrir_modal(pos) {
  // Si ya tiene asignación, el click la deshace
  if (cambios_ot[pos] !== undefined) { clearPos(pos); return; }
  current_pos = pos;
  document.getElementById('back').style.display = 'block';
  document.getElementById('filter_list').style.display = 'block';
  document.getElementById('rueda_list').innerHTML = '';
  filtrar_ot();
}

function cerrar_modal() {
  document.getElementById('back').style.display = 'none';
  document.getElementById('filter_list').style.display = 'none';
  document.getElementById('f_fuego').value = '';
}

function filtrar_ot() {
  var unidadEl = document.getElementById('unidad_id');
  var uid = unidadEl ? unidadEl.value : '';
  $.ajax({ type:'POST', url:'/ajax/listar_ruedas',
    data: { almacen:document.getElementById('f_almacen').value, fuego:document.getElementById('f_fuego').value,
            modelo:document.getElementById('f_modelo').value, medida:document.getElementById('f_medida').value,
            estado:document.getElementById('f_estado').value, modo:'micro' },
    success: function(data) { document.getElementById('rueda_list').innerHTML = data; }
  });
}

function seleccionar_ot(id, fuego) {
  var posNombres = {ddi:'Del. Izq.',ddd:'Del. Der.',tie:'Tras. Izq. Ext.',tii:'Tras. Izq. Int.',
    tdi:'Tras. Der. Int.',tde:'Tras. Der. Ext.',cie:'Cen. Izq. Ext.',cii:'Cen. Izq. Int.',
    cdi:'Cen. Der. Int.',cde:'Cen. Der. Ext.',ra:'Auxilio',ra2:'Auxilio 2'};
  for (var pos in cambios_ot) {
    if (cambios_ot[pos] == id && pos !== current_pos) {
      alert('Esta cubierta ya está asignada en: ' + (posNombres[pos] || pos));
      cerrar_modal();
      return;
    }
  }
  cambios_ot[current_pos] = id;
  var elIn = document.getElementById('fn-in-'+current_pos);
  if (elIn) { elIn.innerHTML = fuego || id; elIn.classList.add('con-valor'); }
  var p = document.getElementById('pos-'+current_pos);
  if (p) p.classList.add('con-entrante');
  cerrar_modal();
}

// Drag-and-drop: swap forzado entre dos posiciones con cubierta
var _dragSrc = null;

function dStart(e, pos) {
  if (!unidadActual[pos]) { e.preventDefault(); return; }
  _dragSrc = pos;
  e.dataTransfer.effectAllowed = 'move';
  setTimeout(function() {
    var el = document.getElementById('pos-'+pos);
    if (el) el.classList.add('dragging');
  }, 0);
}

function dEnd(pos) {
  _dragSrc = null;
  var el = document.getElementById('pos-'+pos);
  if (el) el.classList.remove('dragging');
}

function dOver(e) { e.preventDefault(); return false; }

function dEnter(pos) {
  if (!_dragSrc || _dragSrc === pos) return;
  var el = document.getElementById('pos-'+pos);
  if (el) el.classList.add('drag-over');
}

function dLeave(pos) {
  var el = document.getElementById('pos-'+pos);
  if (el) el.classList.remove('drag-over');
}

function dDrop(e, pos) {
  e.preventDefault();
  e.stopPropagation();
  var el = document.getElementById('pos-'+pos);
  if (el) el.classList.remove('drag-over');
  if (!_dragSrc || _dragSrc === pos) { _dragSrc = null; return false; }

  var srcPos = _dragSrc;
  _dragSrc = null;
  var srcEl = document.getElementById('pos-'+srcPos);
  if (srcEl) srcEl.classList.remove('dragging');

  var u = unidadActual[srcPos];
  if (!u) return false;

  // Movimiento de una sola vía: solo cambia el destino
  cambios_ot[pos] = u.id;
  var elIn = document.getElementById('fn-in-'+pos);
  var pEl  = document.getElementById('pos-'+pos);
  if (elIn) { elIn.innerHTML = u.fuego || '-'; elIn.classList.add('con-valor'); }
  if (pEl)  pEl.classList.add('con-entrante');
  return false;
}

function guardar_ot() {
  var unidad_id  = document.getElementById('unidad_id').value;
  var gomeria_id = document.getElementById('gomeria_id').value;
  var fecha      = document.getElementById('fecha').value;
  if (!unidad_id) { alert('Seleccione una unidad'); return; }
  if (!fecha)     { alert('Ingrese la fecha de solicitud'); return; }
  var tieneTarea = document.getElementById('cb_rotacion').checked ||
                   document.getElementById('cb_arreglo').checked  ||
                   document.getElementById('cb_cambio').checked   ||
                   document.getElementById('cb_alinear').checked  ||
                   document.getElementById('cb_balanceo').checked ||
                   document.getElementById('cb_armar').checked;
  if (!tieneTarea) { alert('Seleccione al menos un trabajo a realizar'); return; }
  $.ajax({ type:'POST', url:'/ajax/nueva_ot',
    data: { unidad_id, gomeria_id, fecha,
            observaciones: document.getElementById('observaciones').value,
            rotacion:  document.getElementById('cb_rotacion').checked  ? '1':'0',
            arreglo:   document.getElementById('cb_arreglo').checked   ? '1':'0',
            cambio:    document.getElementById('cb_cambio').checked    ? '1':'0',
            alinear:   document.getElementById('cb_alinear').checked   ? '1':'0',
            balanceo:  document.getElementById('cb_balanceo').checked  ? '1':'0',
            armar:     document.getElementById('cb_armar').checked     ? '1':'0',
            cambios_ot_json: JSON.stringify(cambios_ot) },
    success: function(id) {
      if (id) location.href = '/OTs/ver?ot='+id;
      else alert('Error al crear la OT');
    },
    error: function(xhr) { alert('Error del servidor: ' + xhr.status + ' ' + xhr.responseText); }
  });
}

$(function() {
  $('#fecha').datepicker({ dateFormat: 'dd/mm/yy' });
  // Al volver al tab, recargar las cubiertas de la unidad seleccionada
  document.addEventListener('visibilitychange', function() {
    if (!document.hidden) {
      var uid = document.getElementById('unidad_id').value;
      if (uid) cargar_tires(uid);
    }
  });
});
</script>

<!-- Modal backdrop -->
<div id="back" onclick="cerrar_modal();"></div>

<!-- Modal selector de cubiertas -->
<div id="filter_list">
  <img src="/images/rojo.png" style="float:right; border:0; margin:2px; height:15px; cursor:pointer;" onclick="cerrar_modal();" />
  <div class="clr"></div>
  <form onsubmit="return false;" style="margin:6px;">
    <strong>Almacén:</strong>
    <select id="f_almacen">
      <option value="0">Todos</option>
      ${almacenes.map(a => `<option value="${a.id}">${a.nombre}</option>`).join('')}
    </select>
    <strong style="margin-left:8px;">Fuego:</strong>
    <input type="text" id="f_fuego" style="width:80px;" />
    <strong style="margin-left:8px;">Modelo:</strong>
    <select id="f_modelo">
      <option value="0">Todos</option>
      ${modelos.map(m => `<option value="${m.id}">${m.marca} ${m.modelo}</option>`).join('')}
    </select>
    <br style="margin:4px 0;" />
    <strong>Medida:</strong>
    <select id="f_medida">
      <option value="0">Todas</option>
      ${medidas.map(m => `<option value="${m.id}">${m.medida}</option>`).join('')}
    </select>
    <strong style="margin-left:8px;">Estado:</strong>
    <select id="f_estado">
      <option value="0">Todos</option>
      <option value="1">Nueva</option>
      <option value="2">Usada</option>
      <option value="3">Recapada</option>
    </select>
    <input type="button" value="Filtrar" onclick="filtrar_ot()" style="margin-left:10px; width:75px;" />
  </form>
  <div id="rueda_list"></div>
</div>

<!-- Titulo -->
<p style="text-align:center; font-size:15px; font-weight:bold; margin-bottom:8px;">Nueva Orden de trabajo</p>

<!-- Imprimir -->
<div style="text-align:right; margin-bottom:6px;">
  <input type="button" value="Imprimir" onclick="window.print();" style="width:90px;" />
</div>

<!-- Campos principales -->
<div style="width:420px; margin:0 auto;">
  <p>
    <strong>Unidad:</strong>
    <select id="unidad_id" style="float:right; width:240px;" onchange="cargar_tires(this.value)">
      <option value="">Seleccione...</option>
      ${unidades.map(u => `<option value="${u.id}">${u.unidad}</option>`).join('')}
    </select>
  </p>
  <p>
    <strong>Gomería:</strong>
    <select id="gomeria_id" style="float:right; width:240px;">
      <option value="">Seleccione...</option>
      ${gomerias.map(g => `<option value="${g.id}">${g.nombre}</option>`).join('')}
    </select>
  </p>
  <p>
    <strong>Fecha de solicitud:</strong>
    <input type="text" id="fecha" style="float:right; width:130px;" value="${hoy}" placeholder="DD/MM/AAAA" />
  </p>
  <div class="clr"></div>
</div>

<!-- Trabajo a realizar -->
<div style="width:420px; margin:10px auto; border:1px solid #ccc; padding:8px;">
  <strong>Trabajo a realizar:</strong>
  <div style="margin-top:6px; display:grid; grid-template-columns:1fr 1fr; gap:4px 20px;">
    <label><input type="checkbox" id="cb_rotacion" /> Rotación</label>
    <label><input type="checkbox" id="cb_arreglo" /> Arreglo</label>
    <label><input type="checkbox" id="cb_cambio" /> Cambio</label>
    <label><input type="checkbox" id="cb_alinear" /> Alinear</label>
    <label><input type="checkbox" id="cb_balanceo" /> Balanceo</label>
    <label><input type="checkbox" id="cb_armar" /> Armar</label>
  </div>
</div>

<!-- Observaciones -->
<div style="width:420px; margin:10px auto; border:1px solid #ccc; padding:8px;">
  <strong>Observaciones:</strong><br style="margin:4px 0;" />
  <textarea id="observaciones" style="width:100%; height:60px; margin-top:4px; resize:vertical;"></textarea>
</div>

<!-- Diagrama de cubiertas -->
<div style="width:420px; margin:10px auto; border:1px solid #ccc; padding:8px;">
  <strong>Cambio de cubiertas:</strong>
  <p style="font-size:11px; color:#666; margin:2px 0 6px 0;">Arrastrá para rotar entre posiciones &nbsp;·&nbsp; Clic en asignada para deshacer &nbsp;·&nbsp; Clic en vacía para cambiar desde almacén</p>
  <div id="diagrama-wrap" style="text-align:center;">
    <p style="color:#999; font-size:12px;">Seleccione una unidad para ver el diagrama</p>
  </div>
</div>

<!-- Botones finales -->
<div style="width:420px; margin:10px auto; text-align:center;">
  <input type="button" value="Generar" onclick="guardar_ot();" style="width:100px;" />
  <input type="button" value="Cancelar" onclick="location.href='/OTs/list';" style="width:100px; margin-left:20px;" />
</div>
`;
%>
<%- include('../layout', { body, user, currentPage }) %>
