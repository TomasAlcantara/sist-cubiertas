<%
const currentPage = 'inicio';
const fechaFormateada = ot.fecha ? new Date(ot.fecha).toLocaleDateString('es-AR') : '';
const cubCargadas = {};
ot_cubiertas.forEach(c => { cubCargadas[c.posicion] = { id: c.cubierta_id, fuego: c.fuego }; });
const cambiosIniciales = {};
ot_cubiertas.forEach(c => { cambiosIniciales[c.posicion] = c.cubierta_id; });
const fuegosEnviados = ot_cubiertas.length
  ? ot_cubiertas.map(c => c.fuego || 'S/N').join(' | ')
  : 'S/N';
const siNo = (v) => v ? '<strong class="text-si">SI</strong>' : '<strong class="text-no">NO</strong>';
// Mapa de cubiertas actuales de la unidad (para mostrar salientes)
const cubUnidadMap = {};
(unitTires || []).forEach(t => { cubUnidadMap[t.posicion] = { id: t.id, fuego: t.fuego }; });
const body = `
<style>
.bus-row { display:flex; align-items:center; justify-content:center; }
.rueda {
  width:58px; height:88px; background:#111; border:2px solid #444;
  display:inline-flex; align-items:stretch; cursor:grab; margin:2px;
  flex-direction:column; overflow:hidden;
}
.rueda:active { cursor:grabbing; }
.rueda:hover { background:#1a1a1a; border-color:#666; }
.rueda.con-entrante { border-color:#2e7d32; background:#0a1f0a; }
.rueda.dragging { opacity:0.3; border-style:dashed; }
.rueda.drag-over { border-color:#fff !important; background:#1a2a1a !important; box-shadow:0 0 0 2px #fff; }
.rueda-out {
  flex:1; display:flex; align-items:center; justify-content:center;
  border-bottom:1px solid #333;
  font-family:'IBM Plex Mono',monospace; font-size:9px; font-weight:600;
  font-variant-numeric:slashed-zero; text-align:center; word-break:break-all;
  line-height:1.2; padding:2px; color:#888;
}
.rueda-out.vacia { color:#2a2a2a; font-size:14px; }
.rueda-in {
  flex:1; display:flex; align-items:center; justify-content:center;
  font-family:'IBM Plex Mono',monospace; font-size:9px; font-weight:600;
  font-variant-numeric:slashed-zero; text-align:center; word-break:break-all;
  line-height:1.2; padding:2px; color:#555;
}
.rueda-in.con-valor { color:#4caf50; }
.bus-top-bot { background:#fff; border:2px solid #333; width:200px; height:16px; }
.bus-side { background:#fff; border-left:2px solid #333; border-right:2px solid #333; width:200px; }
.bus-axle { background:#ddd; border-left:2px solid #333; border-right:2px solid #333; width:200px; height:24px; }
.bus-spacer { width:56px; }
.aux-row { margin-top:8px; display:flex; align-items:center; justify-content:center; gap:8px; }
.aux-row span { font-size:12px; font-weight:bold; }
</style>

<script>
var cambios_ot = ${JSON.stringify(cambiosIniciales)};
var current_pos = '';
var unidadActual = ${JSON.stringify(cubUnidadMap)};

var LAYOUTS = {
  1: { del:['ddi','ddd'], tr1:['tie','tde'],             tr2:[], aux:['ra'],        bodyH:140 },
  2: { del:['ddi','ddd'], tr1:['cie','cii','cdi','cde'], tr2:['tie','tde'], aux:['ra','ra2'], bodyH:80 },
  3: { del:['ddi','ddd'], tr1:['tie','tii','tdi','tde'], tr2:[], aux:['ra','ra2'], bodyH:140 },
  4: { del:['ddi','ddd'], tr1:['tie','tii','tdi','tde'], tr2:[], aux:['ra','ra2'], bodyH:140 }
};

function mkRueda(pos) {
  var curr = unidadActual[pos];
  var outTxt  = curr ? (curr.fuego || '-') : '·';
  var outCls  = curr ? 'rueda-out' : 'rueda-out vacia';
  return '<div class="rueda" id="pos-'+pos+'" draggable="true" '+
    'onclick="abrir_modal(\\''+pos+'\\');" '+
    'ondragstart="dStart(event,\\''+pos+'\\');" '+
    'ondragend="dEnd(\\''+pos+'\\');" '+
    'ondragover="dOver(event);" '+
    'ondragenter="dEnter(\\''+pos+'\\');" '+
    'ondragleave="dLeave(\\''+pos+'\\');" '+
    'ondrop="dDrop(event,\\''+pos+'\\');">'+
    '<span class="'+outCls+'" id="fn-out-'+pos+'">'+outTxt+'</span>'+
    '<span class="rueda-in" id="fn-in-'+pos+'">+</span>'+
    '</div>';
}

function renderDiagrama(tipo) {
  var L = LAYOUTS[tipo] || LAYOUTS[1];
  var del = L.del, tr1 = L.tr1, tr2 = L.tr2;
  var midD = Math.ceil(del.length/2), midT = Math.ceil(tr1.length/2);
  var h = '';
  h += '<div class="bus-row">';
  del.slice(0,midD).forEach(function(p){ h += mkRueda(p); });
  h += '<div class="bus-spacer"></div><div style="width:200px;"></div><div class="bus-spacer"></div>';
  del.slice(midD).forEach(function(p){ h += mkRueda(p); });
  h += '</div>';
  h += '<div class="bus-row"><div class="bus-spacer"></div><div class="bus-top-bot"></div><div class="bus-spacer"></div></div>';
  h += '<div class="bus-row"><div class="bus-spacer"></div><div class="bus-side" style="height:'+L.bodyH+'px;"></div><div class="bus-spacer"></div></div>';
  h += '<div class="bus-row"><div class="bus-spacer"></div><div class="bus-top-bot"></div><div class="bus-spacer"></div></div>';
  h += '<div class="bus-row">';
  tr1.slice(0,midT).forEach(function(p){ h += mkRueda(p); });
  h += '<div class="bus-axle"></div>';
  tr1.slice(midT).forEach(function(p){ h += mkRueda(p); });
  h += '</div>';
  if (tr2.length) {
    var midT2 = Math.ceil(tr2.length/2);
    h += '<div class="bus-row">';
    tr2.slice(0,midT2).forEach(function(p){ h += mkRueda(p); });
    h += '<div class="bus-axle"></div>';
    tr2.slice(midT2).forEach(function(p){ h += mkRueda(p); });
    h += '</div>';
  }
  var auxList = L.aux || ['ra','ra2'];
  h += '<div class="aux-row"><span>Auxilio</span>' + auxList.map(function(p){ return mkRueda(p); }).join('') + '</div>';
  document.getElementById('diagrama-wrap').innerHTML = h;
  // Inicializar cubiertas ya asignadas a esta OT (fila entrante)
  var cargadas = ${JSON.stringify(cubCargadas)};
  Object.keys(cargadas).forEach(function(pos) {
    var elIn = document.getElementById('fn-in-'+pos);
    var p    = document.getElementById('pos-'+pos);
    if (elIn) { elIn.innerHTML = cargadas[pos].fuego || '-'; elIn.classList.add('con-valor'); }
    if (p)    { p.classList.add('con-entrante'); }
  });
}

function mkRuedaStatic(pos) {
  var curr = unidadActual[pos];
  var outTxt = curr ? (curr.fuego || '-') : '·';
  var outCls = curr ? 'rueda-out' : 'rueda-out vacia';
  return '<div class="rueda" style="cursor:default;">'+
    '<span class="'+outCls+'">'+outTxt+'</span>'+
    '</div>';
}

function renderDiagramaStatic(tipo) {
  var L = LAYOUTS[tipo] || LAYOUTS[1];
  var del = L.del, tr1 = L.tr1, tr2 = L.tr2;
  var midD = Math.ceil(del.length/2), midT = Math.ceil(tr1.length/2);
  var h = '';
  h += '<div class="bus-row">';
  del.slice(0,midD).forEach(function(p){ h += mkRuedaStatic(p); });
  h += '<div class="bus-spacer"></div><div style="width:200px;"></div><div class="bus-spacer"></div>';
  del.slice(midD).forEach(function(p){ h += mkRuedaStatic(p); });
  h += '</div>';
  h += '<div class="bus-row"><div class="bus-spacer"></div><div class="bus-top-bot"></div><div class="bus-spacer"></div></div>';
  h += '<div class="bus-row"><div class="bus-spacer"></div><div class="bus-side" style="height:'+L.bodyH+'px;"></div><div class="bus-spacer"></div></div>';
  h += '<div class="bus-row"><div class="bus-spacer"></div><div class="bus-top-bot"></div><div class="bus-spacer"></div></div>';
  h += '<div class="bus-row">';
  tr1.slice(0,midT).forEach(function(p){ h += mkRuedaStatic(p); });
  h += '<div class="bus-axle"></div>';
  tr1.slice(midT).forEach(function(p){ h += mkRuedaStatic(p); });
  h += '</div>';
  if (tr2.length) {
    var midT2 = Math.ceil(tr2.length/2);
    h += '<div class="bus-row">';
    tr2.slice(0,midT2).forEach(function(p){ h += mkRuedaStatic(p); });
    h += '<div class="bus-axle"></div>';
    tr2.slice(midT2).forEach(function(p){ h += mkRuedaStatic(p); });
    h += '</div>';
  }
  var auxList = L.aux || ['ra','ra2'];
  h += '<div class="aux-row"><span>Auxilio</span>' + auxList.map(function(p){ return mkRuedaStatic(p); }).join('') + '</div>';
  document.getElementById('diagrama-antes').innerHTML = h;
}

function abrir_modal(pos) {
  current_pos = pos;
  document.getElementById('back').style.display = 'block';
  document.getElementById('filter_list').style.display = 'block';
  document.getElementById('rueda_list').innerHTML = '';
  filtrar_ot();
}

function cerrar_modal() {
  document.getElementById('back').style.display = 'none';
  document.getElementById('filter_list').style.display = 'none';
  document.getElementById('f_fuego').value = '';
}

function filtrar_ot() {
  $.ajax({ type:'POST', url:'/ajax/listar_ruedas',
    data: { almacen:document.getElementById('f_almacen').value, fuego:document.getElementById('f_fuego').value,
            modelo:document.getElementById('f_modelo').value, medida:document.getElementById('f_medida').value,
            estado:document.getElementById('f_estado').value, orden:document.getElementById('f_orden').value,
            modo:'ot', unidad_id:'${ot.unidad_id || ''}', current_pos:current_pos },
    success: function(data) { document.getElementById('rueda_list').innerHTML = data; }
  });
}

function seleccionar_ot(id, fuego) {
  var posNombres = {ddi:'Del. Izq.',ddd:'Del. Der.',tie:'Tras. Izq. Ext.',tii:'Tras. Izq. Int.',
    tdi:'Tras. Der. Int.',tde:'Tras. Der. Ext.',cie:'Cen. Izq. Ext.',cii:'Cen. Izq. Int.',
    cdi:'Cen. Der. Int.',cde:'Cen. Der. Ext.',ra:'Auxilio',ra2:'Auxilio 2'};
  for (var pos in cambios_ot) {
    if (cambios_ot[pos] == id && pos !== current_pos) {
      alert('Esta cubierta ya está asignada en: ' + (posNombres[pos] || pos));
      cerrar_modal();
      return;
    }
  }
  cambios_ot[current_pos] = id;
  var elIn = document.getElementById('fn-in-'+current_pos);
  if (elIn) { elIn.innerHTML = fuego || id; elIn.classList.add('con-valor'); }
  var p = document.getElementById('pos-'+current_pos);
  if (p) p.classList.add('con-entrante');
  cerrar_modal();
  actualizar_tabla_resumen();
}

// Drag-and-drop: arrastrar rueda sobre otra para intercambiar cubiertas
var _dragSrc = null;

function dStart(e, pos) {
  _dragSrc = pos;
  e.dataTransfer.effectAllowed = 'move';
  setTimeout(function() {
    var el = document.getElementById('pos-'+pos);
    if (el) el.classList.add('dragging');
  }, 0);
}

function dEnd(pos) {
  _dragSrc = null;
  var el = document.getElementById('pos-'+pos);
  if (el) el.classList.remove('dragging');
}

function dOver(e) { e.preventDefault(); return false; }

function dEnter(pos) {
  if (_dragSrc && _dragSrc !== pos) {
    var el = document.getElementById('pos-'+pos);
    if (el) el.classList.add('drag-over');
  }
}

function dLeave(pos) {
  var el = document.getElementById('pos-'+pos);
  if (el) el.classList.remove('drag-over');
}

function dDrop(e, pos) {
  e.preventDefault();
  e.stopPropagation();
  var el = document.getElementById('pos-'+pos);
  if (el) el.classList.remove('drag-over');
  if (!_dragSrc || _dragSrc === pos) { _dragSrc = null; return false; }

  var srcPos = _dragSrc;
  _dragSrc = null;
  var srcEl = document.getElementById('pos-'+srcPos);
  if (srcEl) srcEl.classList.remove('dragging');

  function getTire(p) {
    if (cambios_ot[p] !== undefined) {
      var fnIn = document.getElementById('fn-in-'+p);
      return { id: cambios_ot[p], fuego: fnIn ? fnIn.innerHTML : '-' };
    }
    var u = unidadActual[p];
    return u ? { id: u.id, fuego: u.fuego || '-' } : null;
  }

  function setPos(p, tire) {
    var elIn = document.getElementById('fn-in-'+p);
    var pEl  = document.getElementById('pos-'+p);
    if (tire) {
      cambios_ot[p] = tire.id;
      if (elIn) { elIn.innerHTML = tire.fuego; elIn.classList.add('con-valor'); }
      if (pEl)  pEl.classList.add('con-entrante');
    } else {
      delete cambios_ot[p];
      if (elIn) { elIn.innerHTML = '+'; elIn.classList.remove('con-valor'); }
      if (pEl)  pEl.classList.remove('con-entrante');
    }
  }

  var srcTire = getTire(srcPos);
  var dstTire = getTire(pos);
  if (!srcTire && !dstTire) return false;

  setPos(srcPos, dstTire);
  setPos(pos, srcTire);
  actualizar_tabla_resumen();
  return false;
}

function actualizar_tabla_resumen() {
  var filas = '';
  var posNombres = {ddi:'Del. Izq.',ddd:'Del. Der.',tie:'Tras. Izq. Ext.',tii:'Tras. Izq. Int.',
    tdi:'Tras. Der. Int.',tde:'Tras. Der. Ext.',cie:'Cen. Izq. Ext.',cii:'Cen. Izq. Int.',
    cdi:'Cen. Der. Int.',cde:'Cen. Der. Ext.',ra:'Auxilio',ra2:'Auxilio 2'};
  for (var pos in cambios_ot) {
    var elIn = document.getElementById('fn-in-'+pos);
    filas += '<tr><td>' + (posNombres[pos]||pos) + '</td><td>' + (elIn ? elIn.innerHTML : '-') + '</td></tr>';
  }
  var tbody = document.getElementById('resumen-body');
  if (tbody) tbody.innerHTML = filas || '<tr><td colspan="2" style="color:var(--text-muted);">Sin cambios registrados</td></tr>';
}

function finalizar() {
  $.ajax({ type:'POST', url:'/ajax/actualizar_ot',
    data: {
      ot_id: ${ot.id},
      unidad_id: '${ot.unidad_id||''}',
      gomeria_id: '${ot.gomeria_id||''}',
      fecha: '${fechaFormateada}',
      observaciones: document.getElementById('observaciones').value,
      rotacion:  document.getElementById('cb_rotacion').checked  ? '1':'0',
      arreglo:   document.getElementById('cb_arreglo').checked   ? '1':'0',
      cambio:    document.getElementById('cb_cambio').checked    ? '1':'0',
      alinear:   document.getElementById('cb_alinear').checked   ? '1':'0',
      balanceo:  document.getElementById('cb_balanceo').checked  ? '1':'0',
      armar:     document.getElementById('cb_armar').checked     ? '1':'0',
      cambios_ot_json: JSON.stringify(cambios_ot)
    },
    success: function(id) {
      if (id) location.href = '/OTs/list';
      else alert('Error al guardar');
    },
    error: function(xhr) { alert('Error del servidor: ' + xhr.status); }
  });
}

$(function() {
  var tipo = ${ot.tipo_unidad || 1};
  renderDiagramaStatic(tipo);
  renderDiagrama(tipo);
});
</script>

<div class="modal-overlay" id="back" onclick="cerrar_modal();"></div>
<div class="modal-panel" id="filter_list" style="width:600px; max-height:calc(100vh - 100px); padding:0;">
  <button class="modal-close" onclick="cerrar_modal();">&times;</button>
  <form onsubmit="return false;" class="list-filters" style="padding:12px 14px 8px;">
    <strong>Almacén:</strong>
    <select id="f_almacen">
      <option value="0">Todos</option>
      ${almacenes.map(a => '<option value="' + a.id + '">' + a.nombre + '</option>').join('')}
    </select>
    <strong>Fuego:</strong>
    <input type="text" id="f_fuego" style="width:80px;" />
    <select id="f_orden" style="width:76px;" onchange="filtrar_ot()">
      <option value="asc">↑ Asc</option>
      <option value="desc">↓ Desc</option>
    </select>
    <strong>Modelo:</strong>
    <select id="f_modelo">
      <option value="0">Todos</option>
      ${modelos.map(m => '<option value="' + m.id + '">' + m.marca + ' ' + m.modelo + '</option>').join('')}
    </select>
    <strong>Medida:</strong>
    <select id="f_medida">
      <option value="0">Todas</option>
      ${medidas.map(m => '<option value="' + m.id + '">' + m.medida + '</option>').join('')}
    </select>
    <strong>Estado:</strong>
    <select id="f_estado">
      <option value="0">Todos</option>
      <option value="1">Nueva</option>
      <option value="2">Usada</option>
      <option value="3">Recapada</option>
    </select>
    <button type="button" class="btn-filter" onclick="filtrar_ot()">Filtrar</button>
  </form>
  <div id="rueda_list" style="padding:0 14px 14px;"></div>
</div>

<!-- ORDEN DE TRABAJO -->
<p style="text-align:center; font-size:15px; font-weight:bold; margin-bottom:8px;">ORDEN DE TRABAJO</p>

<!-- Info principal — estilo igual que nueva OT -->
<div style="width:420px; margin:0 auto;">
  <p><strong>Unidad:</strong> <span style="float:right;">${ot.unidad||'-'}</span></p>
  <p><strong>Gomería:</strong> <span style="float:right;">${ot.gomeria_nombre||'-'}</span></p>
  <p><strong>Fecha de solicitud:</strong> <span style="float:right;">${fechaFormateada}</span></p>
  <div style="clear:both;"></div>
</div>

<!-- Trabajos a realizar — bloque bordeado como nueva OT -->
<div style="width:420px; margin:10px auto; border:1px solid #333; padding:8px;">
  <strong>Trabajos a realizar:</strong>
  <div style="margin-top:6px; display:grid; grid-template-columns:1fr 1fr; gap:4px 20px;">
    <span>Rotación: ${siNo(ot.rotacion)}</span>
    <span>Arreglo: ${siNo(ot.arreglo)}</span>
    <span>Cambio: ${siNo(ot.cambio)}</span>
    <span>Alinear: ${siNo(ot.alinear)}</span>
    <span>Balanceo: ${siNo(ot.balanceo)}</span>
    <span>Armar: ${siNo(ot.armar)}</span>
    <span>Pinchadura: ${siNo(ot.pinchadura)}</span>
  </div>
</div>

<!-- Cubiertas enviadas -->
<div style="width:420px; margin:6px auto; text-align:center; font-size:12px; color:var(--text-muted);">
  <strong style="color:var(--text-primary);">Cubiertas enviadas:</strong> ${fuegosEnviados}
</div>

<!-- Comparativa: estado actual + cambios propuestos -->
<div style="width:420px; margin:10px auto; border:1px solid #333; padding:8px;">
  <strong>Cambio de cubiertas:</strong>
  <p style="font-size:11px; color:#666; margin:2px 0 8px 0;">Arrastrá para rotar &nbsp;·&nbsp; Clic en vacía para asignar desde almacén</p>
  <div class="comparativa-wrap">
    <div class="comparativa-lado">
      <div style="text-align:center; font-size:11px; font-weight:600; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.06em; margin-bottom:6px;">Estado actual</div>
      <div id="diagrama-antes" style="text-align:center;"></div>
    </div>
    <div class="comparativa-lado">
      <div style="text-align:center; font-size:11px; font-weight:600; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.06em; margin-bottom:6px;">Cambios propuestos</div>
      <div id="diagrama-wrap" style="text-align:center;"></div>
    </div>
  </div>
</div>

<hr class="ot-sep">

<!-- TRABAJOS REALIZADOS — bloque bordeado como nueva OT -->
<div style="width:420px; margin:10px auto; border:1px solid #333; padding:8px;">
  <strong>Trabajos realizados:</strong>
  <div style="margin-top:6px; display:grid; grid-template-columns:1fr 1fr; gap:4px 20px;">
    <label><input type="checkbox" id="cb_rotacion" ${ot.rotacion?'checked':''} /> Rotación</label>
    <label><input type="checkbox" id="cb_arreglo"  ${ot.arreglo ?'checked':''} /> Arreglo</label>
    <label><input type="checkbox" id="cb_cambio"   ${ot.cambio  ?'checked':''} /> Cambio</label>
    <label><input type="checkbox" id="cb_alinear"  ${ot.alinear ?'checked':''} /> Alinear</label>
    <label><input type="checkbox" id="cb_balanceo" ${ot.balanceo?'checked':''} /> Balanceo</label>
    <label><input type="checkbox" id="cb_armar"    ${ot.armar   ?'checked':''} /> Armar</label>
  </div>
</div>

<!-- Observaciones — bloque bordeado como nueva OT -->
<div style="width:420px; margin:10px auto; border:1px solid #333; padding:8px;">
  <strong>Observaciones:</strong><br style="margin:4px 0;" />
  <textarea id="observaciones" style="width:100%; height:60px; margin-top:4px; resize:vertical;">${ot.observaciones||''}</textarea>
</div>

<div style="width:420px; margin:10px auto; text-align:center; display:flex; gap:10px; justify-content:center;">
  <button class="btn-primary" onclick="finalizar()">Guardar</button>
  <button class="btn-ghost"   onclick="location.href='/OTs/list'">Cancelar</button>
</div>

<hr class="ot-sep">

<!-- RESUMEN CAMBIO DE CUBIERTAS -->
<div style="width:420px; margin:10px auto; border:1px solid #333; padding:8px;">
  <strong>Resumen de cambios:</strong>
  <table style="margin-top:8px;">
    <thead>
      <th>Posición</th><th>Fuego</th>
    </thead>
    <tbody id="resumen-body">
      ${ot_cubiertas.length === 0
        ? '<tr><td colspan="2" style="color:var(--text-muted);">Sin cambios registrados</td></tr>'
        : ot_cubiertas.map(c => {
            const posNombres = {ddi:'Del. Izq.',ddd:'Del. Der.',tie:'Tras. Izq. Ext.',tii:'Tras. Izq. Int.',
              tdi:'Tras. Der. Int.',tde:'Tras. Der. Ext.',cie:'Cen. Izq. Ext.',cii:'Cen. Izq. Int.',
              cdi:'Cen. Der. Int.',cde:'Cen. Der. Ext.',ra:'Auxilio',ra2:'Auxilio 2'};
            return '<tr><td>' + (posNombres[c.posicion]||c.posicion||'-') + '</td><td>' + (c.fuego||'S/N') + '</td></tr>';
          }).join('')
      }
    </tbody>
  </table>
</div>

<div style="width:420px; margin:10px auto; text-align:center; display:flex; gap:10px; justify-content:center;">
  <button class="btn-primary" onclick="finalizar()">Finalizar</button>
  <button class="btn-ghost"   onclick="location.href='/OTs/list'">Cancelar</button>
</div>
`;
%>
<%- include('../layout', { body, user, currentPage }) %>
