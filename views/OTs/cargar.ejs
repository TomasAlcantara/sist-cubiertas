<%
const currentPage = 'inicio';
const fechaFormateada = ot.fecha ? new Date(ot.fecha).toLocaleDateString('es-AR') : '';
const cubCargadas = {};
ot_cubiertas.forEach(c => { cubCargadas[c.posicion] = { id: c.cubierta_id, fuego: c.fuego }; });
const cambiosIniciales = {};
ot_cubiertas.forEach(c => { cambiosIniciales[c.posicion] = c.cubierta_id; });
// Fuegos enviados separados por |
const fuegosEnviados = ot_cubiertas.length
  ? ot_cubiertas.map(c => c.fuego || 'S/N').join(' | ')
  : 'S/N';
const siNo = (v) => v ? '<strong style="color:#090">SI</strong>' : '<strong style="color:#c00">NO</strong>';
const body = `
<style>
#back { display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:98; }
#filter_list { display:none; width:600px; padding:10px; position:fixed; background:#FFF; z-index:99; top:60px; left:50%; transform:translateX(-50%); overflow:auto; max-height:560px; border:1px solid #aaa; box-shadow:2px 2px 8px rgba(0,0,0,0.3); }
#rueda_list table { width:100%; border-collapse:collapse; }
#rueda_list td, #rueda_list th { padding:3px 6px; border:1px solid #ddd; font-size:12px; }
.bus-row { display:flex; align-items:center; justify-content:center; }
.rueda { width:52px; height:68px; background:#111; border:2px solid #444; display:inline-flex; align-items:center; justify-content:center; cursor:pointer; margin:2px; flex-direction:column; }
.rueda:hover { background:#222; border-color:#666; }
.rueda.seleccionada { border-color:#c00; background:#3a0000; }
.rueda .fn { color:#fff; font-size:10px; font-weight:bold; text-align:center; word-break:break-all; line-height:1.2; padding:2px; }
.rueda .fn.vacia { color:#555; font-size:18px; }
.rueda.seleccionada .fn { color:#cc0000; }
.bus-top-bot { background:#fff; border:2px solid #333; width:200px; height:16px; }
.bus-side { background:#fff; border-left:2px solid #333; border-right:2px solid #333; width:200px; }
.bus-axle { background:#ddd; border-left:2px solid #333; border-right:2px solid #333; width:200px; height:24px; }
.bus-spacer { width:56px; }
.aux-row { margin-top:8px; display:flex; align-items:center; justify-content:center; gap:8px; }
.aux-row span { font-size:12px; font-weight:bold; }
.sep { border:none; border-top:1px dashed #999; margin:18px 0; }
.ot-section { width:460px; margin:0 auto; font-size:13px; }
</style>

<script>
var cambios_ot = ${JSON.stringify(cambiosIniciales)};
var current_pos = '';

var LAYOUTS = {
  1: { del:['ddi','ddd'], tr1:['tie','tii','tdi','tde'], tr2:[], bodyH:140 },
  2: { del:['ddi','ddd'], tr1:['cie','cii','cdi','cde'], tr2:['tie','tde'], bodyH:80  },
  3: { del:['ddi','ddd'], tr1:['tie','tde'],              tr2:[], bodyH:140 },
  4: { del:['ddi','ddd'], tr1:['tie','tii','tdi','tde'], tr2:[], bodyH:140 }
};

function mkRueda(pos) {
  return '<div class="rueda" id="pos-'+pos+'" onclick="abrir_modal(\\''+pos+'\\')"><span class="fn vacia" id="fn-'+pos+'">+</span></div>';
}

function renderDiagrama(tipo) {
  var L = LAYOUTS[tipo] || LAYOUTS[1];
  var del = L.del, tr1 = L.tr1, tr2 = L.tr2;
  var midD = Math.ceil(del.length/2), midT = Math.ceil(tr1.length/2);
  var h = '';
  h += '<div class="bus-row">';
  del.slice(0,midD).forEach(function(p){ h += mkRueda(p); });
  h += '<div class="bus-spacer"></div><div style="width:200px;"></div><div class="bus-spacer"></div>';
  del.slice(midD).forEach(function(p){ h += mkRueda(p); });
  h += '</div>';
  h += '<div class="bus-row"><div class="bus-spacer"></div><div class="bus-top-bot"></div><div class="bus-spacer"></div></div>';
  h += '<div class="bus-row"><div class="bus-spacer"></div><div class="bus-side" style="height:'+L.bodyH+'px;"></div><div class="bus-spacer"></div></div>';
  h += '<div class="bus-row"><div class="bus-spacer"></div><div class="bus-top-bot"></div><div class="bus-spacer"></div></div>';
  h += '<div class="bus-row">';
  tr1.slice(0,midT).forEach(function(p){ h += mkRueda(p); });
  h += '<div class="bus-axle"></div>';
  tr1.slice(midT).forEach(function(p){ h += mkRueda(p); });
  h += '</div>';
  if (tr2.length) {
    var midT2 = Math.ceil(tr2.length/2);
    h += '<div class="bus-row">';
    tr2.slice(0,midT2).forEach(function(p){ h += mkRueda(p); });
    h += '<div class="bus-axle"></div>';
    tr2.slice(midT2).forEach(function(p){ h += mkRueda(p); });
    h += '</div>';
  }
  h += '<div class="aux-row"><span>Auxilio</span>'+mkRueda('ra')+mkRueda('ra2')+'</div>';
  document.getElementById('diagrama-wrap').innerHTML = h;
  // Pre-marcar cubiertas ya asignadas
  var cargadas = ${JSON.stringify(cubCargadas)};
  Object.keys(cargadas).forEach(function(pos) {
    var el = document.getElementById('fn-'+pos);
    var p  = document.getElementById('pos-'+pos);
    if (el) { el.innerHTML = cargadas[pos].fuego || '-'; el.classList.remove('vacia'); }
    if (p)  { p.classList.add('seleccionada'); }
  });
}

function abrir_modal(pos) {
  current_pos = pos;
  document.getElementById('back').style.display = 'block';
  document.getElementById('filter_list').style.display = 'block';
  document.getElementById('rueda_list').innerHTML = '';
  filtrar_ot();
}

function cerrar_modal() {
  document.getElementById('back').style.display = 'none';
  document.getElementById('filter_list').style.display = 'none';
}

function filtrar_ot() {
  $.ajax({ type:'POST', url:'/ajax/listar_ruedas',
    data: { almacen:document.getElementById('f_almacen').value, fuego:document.getElementById('f_fuego').value,
            modelo:document.getElementById('f_modelo').value, medida:document.getElementById('f_medida').value,
            estado:document.getElementById('f_estado').value, modo:'ot' },
    success: function(data) { document.getElementById('rueda_list').innerHTML = data; }
  });
}

function seleccionar_ot(id, fuego) {
  cambios_ot[current_pos] = id;
  var el = document.getElementById('fn-'+current_pos);
  if (el) { el.innerHTML = fuego || id; el.classList.remove('vacia'); }
  var p = document.getElementById('pos-'+current_pos);
  if (p) p.classList.add('seleccionada');
  cerrar_modal();
  actualizar_tabla_resumen();
}

function actualizar_tabla_resumen() {
  // Refresca el resumen en tiempo real
  var filas = '';
  var posNombres = {ddi:'Del. Izq.',ddd:'Del. Der.',tie:'Tras. Izq. Ext.',tii:'Tras. Izq. Int.',
    tdi:'Tras. Der. Int.',tde:'Tras. Der. Ext.',cie:'Cen. Izq. Ext.',cii:'Cen. Izq. Int.',
    cdi:'Cen. Der. Int.',cde:'Cen. Der. Ext.',ra:'Auxilio',ra2:'Auxilio 2'};
  for (var pos in cambios_ot) {
    var fn = document.getElementById('fn-'+pos);
    filas += '<tr><td style="padding:2px 6px;">' + (posNombres[pos]||pos) + '</td>'
           + '<td style="padding:2px 6px;">' + (fn ? fn.innerHTML : '-') + '</td></tr>';
  }
  var tbody = document.getElementById('resumen-body');
  if (tbody) tbody.innerHTML = filas || '<tr><td colspan="2" style="color:#999; padding:4px 6px;">Sin cambios registrados</td></tr>';
}

function finalizar() {
  $.ajax({ type:'POST', url:'/ajax/actualizar_ot',
    data: {
      ot_id: ${ot.id},
      unidad_id: '${ot.unidad_id||''}',
      gomeria_id: '${ot.gomeria_id||''}',
      fecha: '${fechaFormateada}',
      observaciones: document.getElementById('observaciones').value,
      rotacion:  document.getElementById('cb_rotacion').checked  ? '1':'0',
      arreglo:   document.getElementById('cb_arreglo').checked   ? '1':'0',
      cambio:    document.getElementById('cb_cambio').checked    ? '1':'0',
      alinear:   document.getElementById('cb_alinear').checked   ? '1':'0',
      balanceo:  document.getElementById('cb_balanceo').checked  ? '1':'0',
      armar:     document.getElementById('cb_armar').checked     ? '1':'0',
      cambios_ot_json: JSON.stringify(cambios_ot)
    },
    success: function(id) {
      if (id) location.href = '/OTs/list';
      else alert('Error al guardar');
    },
    error: function(xhr) { alert('Error del servidor: ' + xhr.status); }
  });
}

$(function() {
  renderDiagrama(${ot.tipo_unidad || 1});
});
</script>

<!-- Modal backdrop -->
<div id="back" onclick="cerrar_modal();"></div>

<!-- Modal selector de cubiertas -->
<div id="filter_list">
  <img src="/images/rojo.png" style="float:right; border:0; margin:2px; height:15px; cursor:pointer;" onclick="cerrar_modal();" />
  <div class="clr"></div>
  <form onsubmit="return false;" style="margin:6px;">
    <strong>Almacén:</strong>
    <select id="f_almacen">
      <option value="0">Todos</option>
      ${almacenes.map(a => '<option value="' + a.id + '">' + a.nombre + '</option>').join('')}
    </select>
    <strong style="margin-left:8px;">Fuego:</strong>
    <input type="text" id="f_fuego" style="width:80px;" />
    <strong style="margin-left:8px;">Modelo:</strong>
    <select id="f_modelo">
      <option value="0">Todos</option>
      ${modelos.map(m => '<option value="' + m.id + '">' + m.marca + ' ' + m.modelo + '</option>').join('')}
    </select>
    <br style="margin:4px 0;" />
    <strong>Medida:</strong>
    <select id="f_medida">
      <option value="0">Todas</option>
      ${medidas.map(m => '<option value="' + m.id + '">' + m.medida + '</option>').join('')}
    </select>
    <strong style="margin-left:8px;">Estado:</strong>
    <select id="f_estado">
      <option value="0">Todos</option>
      <option value="1">Nueva</option>
      <option value="2">Usada</option>
      <option value="3">Recapada</option>
    </select>
    <input type="button" value="Filtrar" onclick="filtrar_ot()" style="margin-left:10px; width:75px;" />
  </form>
  <div id="rueda_list"></div>
</div>

<!-- ===== ORDEN DE TRABAJO ===== -->
<div class="ot-section">
  <h2 style="text-align:center; font-size:18px; font-weight:bold; margin-bottom:14px;">ORDEN DE TRABAJO</h2>

  <div style="display:flex; justify-content:space-between; margin-bottom:10px; font-size:13px;">
    <span><strong>Fecha de solicitud:</strong> ${fechaFormateada}</span>
    <span><strong>Interno:</strong> ${ot.unidad||'-'}</span>
  </div>

  <p style="text-align:center; font-size:13px; margin-bottom:6px;"><strong>Trabajos a realizar:</strong></p>
  <div style="display:grid; grid-template-columns:1fr 1fr; gap:2px 30px; width:280px; margin:0 auto 10px auto; font-size:13px;">
    <span>Rotación: ${siNo(ot.rotacion)}</span>
    <span>Arreglo: ${siNo(ot.arreglo)}</span>
    <span>Cambio: ${siNo(ot.cambio)}</span>
    <span>Alinear: ${siNo(ot.alinear)}</span>
    <span>Balanceo: ${siNo(ot.balanceo)}</span>
    <span>Armar: ${siNo(ot.armar)}</span>
  </div>

  <p style="text-align:center; font-size:12px; margin-bottom:4px;">
    <strong>Número de cubiertas enviadas:</strong><br>
    <span style="color:#444;">${fuegosEnviados}</span>
  </p>

  <p style="text-align:center; font-size:13px; font-weight:bold; margin:12px 0 6px 0;">Cambio de cubiertas:</p>
  <div id="diagrama-wrap" style="text-align:center; margin-bottom:10px;">
    <p style="color:#999; font-size:12px;">Cargando...</p>
  </div>
</div>

<hr class="sep">

<!-- ===== TRABAJOS REALIZADOS ===== -->
<div class="ot-section">
  <p style="text-align:center; font-size:13px; font-weight:bold; margin-bottom:8px;">Trabajos realizados:</p>
  <div style="display:grid; grid-template-columns:1fr 1fr; gap:4px 30px; width:280px; margin:0 auto 10px auto; font-size:13px;">
    <label><input type="checkbox" id="cb_rotacion" ${ot.rotacion?'checked':''} /> Rotación</label>
    <label><input type="checkbox" id="cb_arreglo"  ${ot.arreglo ?'checked':''} /> Arreglo</label>
    <label><input type="checkbox" id="cb_cambio"   ${ot.cambio  ?'checked':''} /> Cambio</label>
    <label><input type="checkbox" id="cb_alinear"  ${ot.alinear ?'checked':''} /> Alinear</label>
    <label><input type="checkbox" id="cb_balanceo" ${ot.balanceo?'checked':''} /> Balanceo</label>
    <label><input type="checkbox" id="cb_armar"    ${ot.armar   ?'checked':''} /> Armar</label>
  </div>

  <p style="font-size:13px; margin:10px 0 4px 0;"><strong>Observaciones:</strong></p>
  <textarea id="observaciones" style="width:100%; height:70px; resize:vertical; font-size:13px;">${ot.observaciones||''}</textarea>

  <div style="text-align:center; margin-top:12px;">
    <input type="button" value="Guardar" onclick="finalizar();" style="width:100px;" />
    <input type="button" value="Cancelar" onclick="location.href='/OTs/list';" style="width:100px; margin-left:20px;" />
  </div>
</div>

<hr class="sep">

<!-- ===== RESUMEN CAMBIO DE CUBIERTAS ===== -->
<div class="ot-section">
  <p style="text-align:center; font-size:13px; font-weight:bold; margin-bottom:8px;">Cambio de cubiertas</p>
  <table style="width:100%; border-collapse:collapse; font-size:13px;">
    <thead>
      <tr>
        <th style="border:1px solid #ccc; padding:4px 8px;">Posición</th>
        <th style="border:1px solid #ccc; padding:4px 8px;">Fuego</th>
      </tr>
    </thead>
    <tbody id="resumen-body">
      ${ot_cubiertas.length === 0
        ? '<tr><td colspan="2" style="color:#999; padding:4px 6px; border:1px solid #ccc;">Sin cambios registrados</td></tr>'
        : ot_cubiertas.map(c => {
            const posNombres = {ddi:'Del. Izq.',ddd:'Del. Der.',tie:'Tras. Izq. Ext.',tii:'Tras. Izq. Int.',
              tdi:'Tras. Der. Int.',tde:'Tras. Der. Ext.',cie:'Cen. Izq. Ext.',cii:'Cen. Izq. Int.',
              cdi:'Cen. Der. Int.',cde:'Cen. Der. Ext.',ra:'Auxilio',ra2:'Auxilio 2'};
            return '<tr><td style="border:1px solid #ccc; padding:4px 8px;">' + (posNombres[c.posicion]||c.posicion||'-') + '</td>'
                 + '<td style="border:1px solid #ccc; padding:4px 8px;">' + (c.fuego||'S/N') + '</td></tr>';
          }).join('')
      }
    </tbody>
  </table>

  <div style="text-align:center; margin-top:14px;">
    <input type="button" value="Finalizar" onclick="finalizar();" style="width:100px;" />
    <input type="button" value="Cancelar" onclick="location.href='/OTs/list';" style="width:100px; margin-left:20px;" />
  </div>
</div>
`;
%>
<%- include('../layout', { body, user, currentPage }) %>
