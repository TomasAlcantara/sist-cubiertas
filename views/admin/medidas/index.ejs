<%
const currentPage = 'admin';
const body = `
<div class="list-head">
  <h2>Medidas</h2>
  <a href="/admin/medidas/nuevo" class="btn-nuevo">Nueva Medida</a>
</div>
<table>
  <thead><th>Medida</th><th style="width:200px;">Editar</th></thead>
  ${medidas.map((m,i)=>`<tr class="${i%2===0?'light':'dark'}">
    <td>${m.medida}</td>
    <td align="center"><a href="/admin/medidas/editar?medida=${m.id}">EDITAR</a></td>
  </tr>`).join('')}
</table>
<a href="/admin" class="list-back">&laquo; Volver</a>
`;
%>
<%- include('../../layout', { body, user, currentPage }) %>
