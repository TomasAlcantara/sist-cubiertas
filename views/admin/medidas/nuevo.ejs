<%
const currentPage = 'admin';
const body = `
<script>
function guardar() {
  var medida = document.getElementById('medida').value;
  if (!medida) { alert('Ingrese la medida'); return; }
  $.ajax({ type:'POST', url:'/ajax/save_medida', data:{ medida },
    success: function(data) { if(data) { alert(data); location.href='/admin/medidas'; } else alert('Error'); }
  });
}
</script>
<div class="form-card">
  <div class="form-header"><h2>Nueva Medida</h2></div>
  <div class="field">
    <label for="medida">Medida</label>
    <input type="text" id="medida" class="text" placeholder="ej: 295/80R22.5" />
  </div>
  <div class="form-actions">
    <button class="btn-primary" onclick="guardar()">Guardar</button>
    <button class="btn-ghost"   onclick="location.href='/admin/medidas'">Cancelar</button>
  </div>
</div>
`;
%>
<%- include('../../layout', { body, user, currentPage }) %>
