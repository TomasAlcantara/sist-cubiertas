<%
const currentPage = 'admin';
const body = `
<script>
function guardar() {
  var medida = document.getElementById('medida').value;
  if (!medida) { alert('Ingrese la medida'); return; }
  $.ajax({ type:'POST', url:'/ajax/save_medida', data:{ medida },
    success: function(data) { if(data) { alert(data); location.href='/admin/medidas'; } else alert('Error'); }
  });
}
</script>
<div style="width:280px; margin:0 auto;">
  <h3>Nueva Medida</h3>
  <p><strong>Medida:</strong> <input type="text" id="medida" placeholder="ej: 295/80R22.5" style="float:right;" /></p>
  <input type="button" value="Guardar" style="float:left;" onclick="guardar();" />
  <input type="button" value="Cancelar" style="float:right;" onclick="location.href='/admin/medidas';" />
  <div class="clr"></div>
</div>
`;
%>
<%- include('../../layout', { body, user, currentPage }) %>
