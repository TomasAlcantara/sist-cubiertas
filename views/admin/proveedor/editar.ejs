<%
const currentPage = 'admin';
const body = `
<script>
function guardar() {
  $.ajax({ type:'POST', url:'/ajax/save_proveedor',
    data:{ id: ${proveedor.id}, proveedor: document.getElementById('proveedor').value,
           tel: document.getElementById('tel').value, mail: document.getElementById('mail').value },
    success: function(data) { if(data) { alert(data); location.href='/admin/proveedor'; } else alert('Error'); }
  });
}
</script>
<div class="form-card">
  <div class="form-header"><h2>Editar Proveedor</h2></div>
  <div class="field">
    <label for="proveedor">Proveedor</label>
    <input type="text" id="proveedor" class="text" value="${e(proveedor.proveedor)}" />
  </div>
  <div class="field">
    <label for="tel">Teléfono</label>
    <input type="text" id="tel" class="text" value="${e(proveedor.tel||'')}" />
  </div>
  <div class="field">
    <label for="mail">Mail</label>
    <input type="text" id="mail" class="text" value="${e(proveedor.mail||'')}" />
  </div>
  <div class="form-actions">
    <button class="btn-primary" onclick="guardar()">Guardar</button>
    <button class="btn-ghost"   onclick="location.href='/admin/proveedor'">Cancelar</button>
  </div>
</div>
`;
%>
<%- include('../../layout', { body, user, currentPage }) %>
