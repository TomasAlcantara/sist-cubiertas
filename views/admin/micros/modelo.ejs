<%
const estadoNombre = (e) => e==1?'Nueva':e==2?'Usada':'Recapada';
const POSICIONES_POR_TIPO = {
  1: ['ddi','ddd','tie','tde','ra'],                                     // Auto/Camioneta: 4R+1aux
  2: ['ddi','ddd','cie','cii','cdi','cde','tie','tde','ra','ra2'],        // Doble Piso: 8R+2aux
  3: ['ddi','ddd','tie','tii','tdi','tde','ra','ra2'],                    // Mini Bus/Colectivo: 6R+2aux
  4: ['ddi','ddd','tie','tii','tdi','tde','ra','ra2']                     // legacy = tipo 3
};
const posiciones = POSICIONES_POR_TIPO[micro.tipo_unidad] || POSICIONES_POR_TIPO[3];
const POS_NOMBRE = {
  ddi:'Del. Izq.', ddd:'Del. Der.',
  tie:'Tras. Izq. Ext.', tii:'Tras. Izq. Int.', tdi:'Tras. Der. Int.', tde:'Tras. Der. Ext.',
  cie:'Cen. Izq. Ext.', cii:'Cen. Izq. Int.', cdi:'Cen. Der. Int.', cde:'Cen. Der. Ext.',
  ra:'Auxilio', ra2:'Auxilio 2'
};
const currentPage = 'admin';
const body = `
<style>
#back, #back2 { position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.6); z-index:90; }
</style>
<script src="/js/almacen.js"></script>
<script>
function showdiv(event, id) {
  document.getElementById('posicion').innerHTML = document.getElementById('cubierta_' + id) ? document.getElementById('cubierta_' + id).innerHTML : '';
  document.getElementById('flotante').style.left = (event.clientX + 15) + 'px';
  document.getElementById('flotante').style.top = (event.clientY + window.scrollY + 15) + 'px';
  document.getElementById('flotante').style.display = 'block';
}
function closediv() { document.getElementById('flotante').style.display = 'none'; }
function almacenar() {
  if (!document.getElementById('almacen_id').value) { alert('Seleccione almacén'); return; }
  $.ajax({ type:'POST', url:'/ajax/almacenar_rueda',
    data:{ r_id: document.getElementById('r_id_selected').value, almacen_id: document.getElementById('almacen_id').value },
    success: function() { location.reload(); }
  });
}
</script>

<div class="modal-overlay" id="back" onclick="close_rlist();"></div>
<div class="modal-panel" id="filter_list" style="width:900px; max-height:500px; padding:0;">
  <button class="modal-close" onclick="close_rlist();">&times;</button>
  <form id="formulario" class="list-filters" style="padding:12px 14px 8px;">
    <input type="hidden" id="pos" name="pos" value="" />
    <input type="hidden" id="micro_id" name="micro_id" value="${micro.id}" />
    <input type="hidden" id="km" name="km" value="${micro.km_actual||0}" />
    <input type="hidden" id="seleccionadas" name="seleccionadas" />
    <strong>Almacén:</strong>
    <select id="almacen" name="almacen">
      <option value="0">Todos</option>
      ${almacenes.map(a=>`<option value="${a.id}">${a.nombre}</option>`).join('')}
    </select>
    <strong>Fuego:</strong>
    <input type="text" id="fuego" name="fuego" style="width:100px;" />
    <strong>Modelo:</strong>
    <select id="modelo" name="modelo">
      <option value="0">Todos</option>
      ${modelos.map(m=>`<option value="${m.id}">${m.marca} ${m.modelo}</option>`).join('')}
    </select>
    <strong>Estado:</strong>
    <select id="estado" name="estado">
      <option value="0">Todos</option>
      <option value="1">Nueva</option>
      <option value="2">Usada</option>
      <option value="3">Recapada</option>
    </select>
    <button type="button" class="btn-filter" onclick="filtrar()">Buscar</button>
  </form>
  <div id="rueda_list" style="padding:0 14px 14px;"></div>
</div>

<div class="modal-overlay" id="back2"></div>
<div class="modal-panel" id="rueda_removida" style="width:340px; padding:20px;">
  <p style="margin-bottom:12px;">La posición estaba ocupada. ¿Almacenar la cubierta removida?</p>
  <input type="hidden" id="r_id_selected" value="" />
  <div class="field">
    <label for="almacen_id">Almacén destino</label>
    <select id="almacen_id">
      <option value="">Seleccione almacén...</option>
      ${almacenes.map(a=>`<option value="${a.id}">${a.nombre}</option>`).join('')}
    </select>
  </div>
  <div class="form-actions">
    <button class="btn-primary" onclick="almacenar()">Almacenar</button>
    <button class="btn-ghost" onclick="document.getElementById('back2').style.display='none'; document.getElementById('rueda_removida').style.display='none'; location.reload();">Ignorar</button>
  </div>
</div>

<div class="list-head">
  <h2>Unidad: ${micro.unidad}</h2>
</div>
<p><strong>Km actual:</strong> ${micro.km_actual||0}</p>

<h3>Cubiertas montadas</h3>
<table>
  <thead><th>Posición</th><th>Fuego</th><th>Modelo</th><th>Medida</th><th>Estado</th><th>Km</th><th></th></thead>
  ${posiciones.map(pos => {
    const r = ruedas.find(x => x.posicion === pos);
    return `<tr>
      <td align="center"><strong>${POS_NOMBRE[pos] || pos.toUpperCase()}</strong></td>
      ${r ? `
        <td align="center"><a style="cursor:pointer;" onmouseover="showdiv(event,'${pos}')" onmouseout="closediv()">${r.fuego||'-'}</a></td>
        <td align="center">${r.marca||''} ${r.modelo_nombre||''}</td>
        <td align="center">${r.medida||'-'}</td>
        <td align="center">${estadoNombre(r.estado)}</td>
        <td align="center">${r.km||0}</td>
        <td align="center"><a style="cursor:pointer;" onclick="show_rlist('/', '${pos}')">CAMBIAR</a></td>
      ` : `
        <td colspan="5" align="center" style="color:var(--text-muted);">Vacío</td>
        <td align="center"><a style="cursor:pointer;" onclick="show_rlist('/', '${pos}')">COLOCAR</a></td>
      `}
    </tr>`;
  }).join('')}
</table>

<div id="flotante"></div>

<a href="/admin/micros" class="list-back">&laquo; Volver</a>
`;
%>
<%- include('../../layout', { body, user, currentPage }) %>
