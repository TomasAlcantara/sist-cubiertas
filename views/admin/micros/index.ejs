<%
const currentPage = 'admin';
const body = `
<div class="list-head">
  <h2>Unidades</h2>
  <a href="/admin/micros/nuevo" class="btn-nuevo">Nueva Unidad</a>
</div>
<form method="get" action="/admin/micros" class="list-filters">
  <strong>Unidad:</strong>
  <select name="id">
    <option value="">Todos</option>
    ${allMicros.map(m=>`<option value="${m.id}">${m.unidad}</option>`).join('')}
  </select>
  <button type="submit" class="btn-filter">Filtrar</button>
</form>
<table>
  <thead><th>Unidad</th><th>Descripción</th><th>Km Actual</th><th>Tipo</th><th style="width:180px;">Editar</th></thead>
  ${micros.map((m,i)=>`<tr class="${i%2===0?'light':'dark'}">
    <td>${m.unidad}</td>
    <td>${m.descripcion||''}</td>
    <td align="center">${m.km_actual||0}</td>
    <td align="center">Tipo ${m.tipo_unidad||1}</td>
    <td align="center">
      <a href="/admin/ruedas_micro/modelo?v=${m.id}">VER</a> |
      <a href="/admin/micros/editar?rueda=${m.id}">EDITAR</a> |
      <a style="cursor:pointer;" onclick="active(${m.id}, ${m.activo==1?0:1}, 'micro')">${m.activo==1?'BAJA':'ALTA'}</a>
    </td>
  </tr>`).join('')}
</table>
${totalPages > 1 ? `<div class="list-pagination">
  ${Array.from({length:totalPages},(_,i)=>i+1).map(p =>
    p==pagina ? `<strong class="pg-current">${p}</strong>` : `<a href='?pagina=${p}'>${p}</a>`
  ).join(' | ')}
</div>` : ''}
<a href="/admin" class="list-back">&laquo; Volver</a>
`;
%>
<%- include('../../layout', { body, user, currentPage }) %>
