<%
const currentPage = 'admin';
const body = `
<script>
function select_tipo(id) {
  document.getElementById('radio_' + id).checked = true;
  for (var i = 1; i <= 4; i++) {
    var img = document.getElementById('mod_' + i);
    if (img) img.src = '/images/modelo' + i + (i == id ? '_check' : '') + '.svg';
  }
}
function check_form() {
  var unidad = document.getElementById('unidad').value;
  var desc = document.getElementById('descripcion').value;
  if (!unidad || !desc) { alert('Complete unidad y descripción'); return; }
  var tipo = document.querySelector('input[name=tipo_unidad]:checked').value;
  var km = document.getElementById('km_actual').value;
  $.ajax({ type:'POST', url:'/ajax/save_micro', data:{ unidad, descripcion: desc, tipo_unidad: tipo, km_actual: km },
    success: function(data) { if(data) { alert(data); location.href='/admin/micros'; } else alert('Error'); }
  });
}
</script>
<div style="width:280px; margin:0 auto;">
  <h3>Nueva Unidad</h3>
  <p><strong>Unidad:</strong> <input type="text" id="unidad" style="float:right;" /></p>
  <p><strong>Descripción:</strong> <input type="text" id="descripcion" style="float:right;" /></p>
  <p><strong>Km Actual:</strong> <input type="text" id="km_actual" value="0" style="float:right; width:80px;" /></p>
  <p><strong>Tipo de unidad:</strong><br/>
    <input type="radio" id="radio_1" name="tipo_unidad" value="1" checked style="display:none;" />
    <input type="radio" id="radio_2" name="tipo_unidad" value="2" style="display:none;" />
    <input type="radio" id="radio_3" name="tipo_unidad" value="3" style="display:none;" />
    <input type="radio" id="radio_4" name="tipo_unidad" value="4" style="display:none;" />
    <img id="mod_1" src="/images/modelo1_check.svg" style="height:75px; cursor:pointer; margin-right:6px;" onclick="select_tipo(1)" title="Tipo 1 — Colectivo eje trasero doble" />
    <img id="mod_2" src="/images/modelo2.svg"       style="height:75px; cursor:pointer; margin-right:6px;" onclick="select_tipo(2)" title="Tipo 2 — Colectivo 3 ejes" />
    <img id="mod_3" src="/images/modelo3.svg"       style="height:75px; cursor:pointer; margin-right:6px;" onclick="select_tipo(3)" title="Tipo 3 — Minibus" />
    <img id="mod_4" src="/images/modelo4.svg"       style="height:75px; cursor:pointer;" onclick="select_tipo(4)" title="Tipo 4 — Colectivo eje trasero doble (alt.)" />
  </p>
  <input type="button" value="Guardar" style="float:left; width:80px;" onclick="check_form();" />
  <input type="button" value="Cancelar" style="float:right; width:80px;" onclick="location.href='/admin/micros';" />
  <div class="clr"></div>
</div>
`;
%>
<%- include('../../layout', { body, user, currentPage }) %>
