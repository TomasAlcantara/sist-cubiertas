<%
const currentPage = 'admin';
const body = `
<script>
function check_form() {
  var unidad = document.getElementById('unidad').value;
  var desc = document.getElementById('descripcion').value;
  if (!unidad || !desc) { alert('Complete unidad y descripción'); return; }
  var tipo = document.querySelector('input[name=tipo_unidad]:checked').value;
  var km = document.getElementById('km_actual').value;
  $.ajax({ type:'POST', url:'/ajax/save_micro', data:{ unidad, descripcion: desc, tipo_unidad: tipo, km_actual: km },
    success: function(data) { if(data) { alert(data); location.href='/admin/micros'; } else alert('Error'); }
  });
}
</script>
<div style="width:320px; margin:0 auto;">
  <h3>Nueva Unidad</h3>
  <p><strong>Unidad:</strong> <input type="text" id="unidad" style="float:right;" /></p>
  <p><strong>Descripción:</strong> <input type="text" id="descripcion" style="float:right;" /></p>
  <p><strong>Km Actual:</strong> <input type="text" id="km_actual" style="float:right;" /></p>
  <p><strong>Tipo:</strong></p>
  <p style="font-size:12px; line-height:2;">
    <label><input type="radio" name="tipo_unidad" value="1" checked /> Tipo 1 — Colectivo eje trasero doble</label><br>
    <label><input type="radio" name="tipo_unidad" value="2" /> Tipo 2 — Colectivo 3 ejes</label><br>
    <label><input type="radio" name="tipo_unidad" value="3" /> Tipo 3 — Minibus (sin ruedas interiores)</label><br>
    <label><input type="radio" name="tipo_unidad" value="4" /> Tipo 4 — Colectivo eje trasero doble (alt.)</label>
  </p>
  <input type="button" value="Guardar" style="float:left;" onclick="check_form();" />
  <input type="button" value="Cancelar" style="float:right;" onclick="location.href='/admin/micros';" />
  <div class="clr"></div>
</div>
`;
%>
<%- include('../../layout', { body, user, currentPage }) %>
