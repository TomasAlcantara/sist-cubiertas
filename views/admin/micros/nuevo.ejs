<%
const currentPage = 'admin';
const body = `
<style>
  .form-card { max-width: 560px; margin: 0 auto; }

  .form-header {
    margin-bottom: 1.75rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }
  .form-header h2 { margin: 0; font-size: 1.6rem; }

  .field-row {
    display: grid;
    grid-template-columns: 1fr 160px;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 5px;
    margin-bottom: 1rem;
  }
  .field label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .field input { width: 100%; }

  .type-section { margin: 0.5rem 0 2rem; }
  .type-section-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 10px;
  }
  .type-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
  }
  .type-card {
    border: 2px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-surface);
    padding: 14px 8px 10px;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    transition: border-color 0.12s, background 0.12s;
    user-select: none;
  }
  .type-card:hover { border-color: var(--border-strong); background: var(--bg-hover); }
  .type-card.selected { border-color: var(--red); background: rgba(192,57,43,0.06); }
  .type-card img { height: 62px; width: auto; display: block; }
  .type-card-label {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.04em;
    color: var(--text-muted);
    text-align: center;
    line-height: 1.35;
  }
  .type-card.selected .type-card-label { color: var(--red); font-weight: 600; }

  .form-actions {
    display: flex;
    gap: 10px;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  .btn-primary {
    background: var(--red); color: #fff; border: none;
    font-family: var(--font-display); font-size: 13px; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    padding: 10px 32px; border-radius: var(--radius);
    cursor: pointer; transition: background 0.12s;
  }
  .btn-primary:hover { background: var(--red-bright); }
  .btn-ghost {
    background: transparent; color: var(--text-secondary);
    border: 1px solid var(--border-strong);
    font-family: var(--font-display); font-size: 13px; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    padding: 10px 28px; border-radius: var(--radius);
    cursor: pointer; transition: all 0.12s;
  }
  .btn-ghost:hover { background: var(--bg-hover); color: var(--text-primary); }
</style>

<script>
function select_tipo(id) {
  document.getElementById('radio_' + id).checked = true;
  document.querySelectorAll('.type-card').forEach(function(c) { c.classList.remove('selected'); });
  document.getElementById('card_' + id).classList.add('selected');
  for (var i = 1; i <= 4; i++) {
    var img = document.getElementById('mod_' + i);
    if (img) img.src = '/images/modelo' + i + (i == id ? '_check' : '') + '.svg';
  }
}
function check_form() {
  var unidad = document.getElementById('unidad').value.trim();
  var desc   = document.getElementById('descripcion').value.trim();
  if (!unidad || !desc) { alert('Complete los campos Unidad y Descripción'); return; }
  var tipo = document.querySelector('input[name=tipo_unidad]:checked').value;
  var km   = document.getElementById('km_actual').value;
  $.ajax({ type:'POST', url:'/ajax/save_micro',
    data:{ unidad, descripcion: desc, tipo_unidad: tipo, km_actual: km },
    success: function(data) { if(data) { alert(data); location.href='/admin/micros'; } else alert('Error al guardar'); }
  });
}
</script>

<div class="form-card">
  <div class="form-header">
    <h2>Nueva Unidad</h2>
  </div>

  <div class="field-row">
    <div class="field">
      <label for="unidad">Unidad</label>
      <input type="text" id="unidad" placeholder="Ej: 101" />
    </div>
    <div class="field">
      <label for="km_actual">Km Actual</label>
      <input type="number" id="km_actual" value="0" min="0" />
    </div>
  </div>

  <div class="field">
    <label for="descripcion">Descripción</label>
    <input type="text" id="descripcion" placeholder="Descripción de la unidad" />
  </div>

  <div class="type-section">
    <div class="type-section-label">Tipo de unidad</div>

    <input type="radio" id="radio_1" name="tipo_unidad" value="1" checked style="display:none;" />
    <input type="radio" id="radio_2" name="tipo_unidad" value="2" style="display:none;" />
    <input type="radio" id="radio_3" name="tipo_unidad" value="3" style="display:none;" />
    <input type="radio" id="radio_4" name="tipo_unidad" value="4" style="display:none;" />

    <div class="type-grid">
      <div class="type-card selected" id="card_1" onclick="select_tipo(1)">
        <img id="mod_1" src="/images/modelo1_check.svg" alt="Tipo 1" />
        <span class="type-card-label">Colectivo<br>eje doble</span>
      </div>
      <div class="type-card" id="card_2" onclick="select_tipo(2)">
        <img id="mod_2" src="/images/modelo2.svg" alt="Tipo 2" />
        <span class="type-card-label">Colectivo<br>3 ejes</span>
      </div>
      <div class="type-card" id="card_3" onclick="select_tipo(3)">
        <img id="mod_3" src="/images/modelo3.svg" alt="Tipo 3" />
        <span class="type-card-label">Minibus</span>
      </div>
      <div class="type-card" id="card_4" onclick="select_tipo(4)">
        <img id="mod_4" src="/images/modelo4.svg" alt="Tipo 4" />
        <span class="type-card-label">Colectivo<br>doble alt.</span>
      </div>
    </div>
  </div>

  <div class="form-actions">
    <button class="btn-primary" onclick="check_form()">Guardar</button>
    <button class="btn-ghost"   onclick="location.href='/admin/micros'">Cancelar</button>
  </div>
</div>
`;
%>
<%- include('../../layout', { body, user, currentPage }) %>
