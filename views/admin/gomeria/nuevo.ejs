<%
const currentPage = 'admin';
const body = `
<script>
function guardar() {
  var nombre = document.getElementById('nombre').value.trim();
  if (!nombre) { alert('Ingrese el nombre'); return; }
  $.ajax({ type:'POST', url:'/ajax/save_gomeria',
    data:{
      nombre,
      direccion: document.getElementById('direccion').value,
      localidad: document.getElementById('localidad').value,
      telefono:  document.getElementById('telefono').value
    },
    success: function(data) { if(data) { alert(data); location.href='/admin/gomeria'; } else alert('Error'); }
  });
}
</script>
<div style="width:340px; margin:0 auto;">
  <h3>Nueva Gomería</h3>
  <p><strong>Nombre:</strong>    <input type="text" id="nombre"    style="float:right; width:190px;" /></p>
  <p><strong>Dirección:</strong> <input type="text" id="direccion" style="float:right; width:190px;" /></p>
  <p><strong>Localidad:</strong> <input type="text" id="localidad" style="float:right; width:190px;" /></p>
  <p><strong>Teléfono:</strong>  <input type="text" id="telefono"  style="float:right; width:190px;" /></p>
  <div style="clear:both; margin-top:10px;">
    <input type="button" value="Guardar"   style="float:left;"  onclick="guardar();" />
    <input type="button" value="Cancelar"  style="float:right;" onclick="location.href='/admin/gomeria';" />
    <div class="clr"></div>
  </div>
</div>
`;
%>
<%- include('../../layout', { body, user, currentPage }) %>
