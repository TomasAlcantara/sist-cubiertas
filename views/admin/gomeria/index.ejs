<%
const currentPage = 'admin';
const body = `
<div class="list-head">
  <h2>Gomerías</h2>
  <a href="/admin/gomeria/nuevo" class="btn-nuevo">Nueva Gomería</a>
</div>
<table>
  <thead><th>Nombre</th><th style="width:200px;">Editar</th></thead>
  ${gomerias.map((g,i)=>`<tr class="${i%2===0?'light':'dark'}">
    <td>${g.nombre}</td>
    <td align="center">
      <a href="/admin/gomeria/editar?id=${g.id}">EDITAR</a> |
      <a style="cursor:pointer;" onclick="active(${g.id}, ${g.activo==1?0:1}, 'gomeria')">${g.activo==1?'BAJA':'ALTA'}</a>
    </td>
  </tr>`).join('')}
</table>
<a href="/admin" class="list-back">&laquo; Volver</a>
`;
%>
<%- include('../../layout', { body, user, currentPage }) %>
