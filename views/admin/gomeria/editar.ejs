<%
const currentPage = 'admin';
const body = `
<script>
function guardar() {
  $.ajax({ type:'POST', url:'/ajax/save_gomeria',
    data:{
      id:        ${gomeria.id},
      nombre:    document.getElementById('nombre').value,
      direccion: document.getElementById('direccion').value,
      localidad: document.getElementById('localidad').value,
      telefono:  document.getElementById('telefono').value
    },
    success: function(data) { if(data) { alert(data); location.href='/admin/gomeria'; } else alert('Error'); }
  });
}
</script>
<div style="width:340px; margin:0 auto;">
  <h3>Editar Gomería</h3>
  <p><strong>Nombre:</strong>    <input type="text" id="nombre"    value="${gomeria.nombre||''}"    style="float:right; width:190px;" /></p>
  <p><strong>Dirección:</strong> <input type="text" id="direccion" value="${gomeria.direccion||''}" style="float:right; width:190px;" /></p>
  <p><strong>Localidad:</strong> <input type="text" id="localidad" value="${gomeria.localidad||''}" style="float:right; width:190px;" /></p>
  <p><strong>Teléfono:</strong>  <input type="text" id="telefono"  value="${gomeria.telefono||''}"  style="float:right; width:190px;" /></p>
  <div style="clear:both; margin-top:10px;">
    <input type="button" value="Guardar"  style="float:left;"  onclick="guardar();" />
    <input type="button" value="Cancelar" style="float:right;" onclick="location.href='/admin/gomeria';" />
    <div class="clr"></div>
  </div>
</div>
`;
%>
<%- include('../../layout', { body, user, currentPage }) %>
