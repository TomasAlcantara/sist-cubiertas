<%
const currentPage = 'admin';
const body = `
<script>
function guardar() {
  var marca = document.getElementById('marca').value;
  var modelo = document.getElementById('modelo').value;
  if (!marca || !modelo) { alert('Complete marca y modelo'); return; }
  $.ajax({ type:'POST', url:'/ajax/save_modelo', data:{ marca, modelo },
    success: function(data) { if(data) { alert(data); location.href='/admin/modelo_cubierta'; } else alert('Error'); }
  });
}
</script>
<div class="form-card">
  <div class="form-header"><h2>Nuevo Modelo de Cubierta</h2></div>
  <div class="field">
    <label for="marca">Marca</label>
    <input type="text" id="marca" class="text" />
  </div>
  <div class="field">
    <label for="modelo">Modelo</label>
    <input type="text" id="modelo" class="text" />
  </div>
  <div class="form-actions">
    <button class="btn-primary" onclick="guardar()">Guardar</button>
    <button class="btn-ghost"   onclick="location.href='/admin/modelo_cubierta'">Cancelar</button>
  </div>
</div>
`;
%>
<%- include('../../layout', { body, user, currentPage }) %>
