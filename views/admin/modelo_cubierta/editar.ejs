<%
const currentPage = 'admin';
const body = `
<script>
function guardar() {
  $.ajax({ type:'POST', url:'/ajax/save_modelo',
    data:{ id: ${modelo.id}, marca: document.getElementById('marca').value, modelo: document.getElementById('modelo').value },
    success: function(data) { if(data) { alert(data); location.href='/admin/modelo_cubierta'; } else alert('Error'); }
  });
}
</script>
<div class="form-card">
  <div class="form-header"><h2>Editar Modelo</h2></div>
  <div class="field">
    <label for="marca">Marca</label>
    <input type="text" id="marca" class="text" value="${modelo.marca}" />
  </div>
  <div class="field">
    <label for="modelo">Modelo</label>
    <input type="text" id="modelo" class="text" value="${modelo.modelo}" />
  </div>
  <div class="form-actions">
    <button class="btn-primary" onclick="guardar()">Guardar</button>
    <button class="btn-ghost"   onclick="location.href='/admin/modelo_cubierta'">Cancelar</button>
  </div>
</div>
`;
%>
<%- include('../../layout', { body, user, currentPage }) %>
