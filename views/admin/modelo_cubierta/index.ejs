<%
const currentPage = 'admin';
const body = `
<div class="list-head">
  <h2>Modelos de Cubierta</h2>
  <label class="list-active-filter">
    <input type="checkbox" id="active_only" checked onclick="solo_activos(this);" />
    Solo activos
  </label>
  <a href="/admin/modelo_cubierta/nuevo" class="btn-nuevo">Nuevo Modelo</a>
</div>
<form method="get" action="/admin/modelo_cubierta" class="list-filters">
  <strong>Marca:</strong>
  <input type="text" name="marca" value="${filtros.marca}" />
  <strong>Modelo:</strong>
  <input type="text" name="modelo" value="${filtros.modelo}" />
  <button type="submit" class="btn-filter">Filtrar</button>
</form>
<table>
  <thead><th>Marca</th><th>Modelo</th><th style="width:150px;">Editar</th></thead>
  ${modelos.map((m,i)=>`<tr class="${i%2===0?'light':'dark'}">
    <td>${m.marca}</td><td>${m.modelo}</td>
    <td align="center">
      <a href="/admin/modelo_cubierta/editar?modelo=${m.id}">EDITAR</a> |
      <a style="cursor:pointer;" onclick="active(${m.id}, ${m.activo==1?0:1}, 'marcas_ruedas')">${m.activo==1?'BAJA':'ALTA'}</a>
    </td>
  </tr>`).join('')}
</table>
${totalPages > 1 ? `<div class="list-pagination">
  ${Array.from({length:totalPages},(_,i)=>i+1).map(p =>
    p==pagina ? `<strong class="pg-current">${p}</strong>` : `<a href='?marca=${filtros.marca}&modelo=${filtros.modelo}&pagina=${p}'>${p}</a>`
  ).join(' | ')}
</div>` : ''}
<a href="/admin" class="list-back">&laquo; Volver</a>
`;
%>
<%- include('../../layout', { body, user, currentPage }) %>
