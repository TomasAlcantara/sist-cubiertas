<%
const currentPage = 'admin';
const body = `
<script>
function guardar() {
  var nombre = document.getElementById('nombre').value.trim();
  if (!nombre) { alert('Ingrese el nombre'); return; }
  $.ajax({ type:'POST', url:'/ajax/save_recapadora',
    data:{
      nombre,
      direccion:    document.getElementById('direccion').value,
      localidad:    document.getElementById('localidad').value,
      telefono:     document.getElementById('telefono').value,
      tipo_trabajo: document.getElementById('tipo_trabajo').value
    },
    success: function(data) { if(data) { alert(data); location.href='/admin/recapadora'; } else alert('Error'); }
  });
}
</script>
<div class="form-card">
  <div class="form-header"><h2>Nueva Recapadora</h2></div>
  <div class="field">
    <label for="nombre">Nombre</label>
    <input type="text" id="nombre" class="text" />
  </div>
  <div class="field">
    <label for="direccion">Dirección</label>
    <input type="text" id="direccion" class="text" />
  </div>
  <div class="field">
    <label for="localidad">Localidad</label>
    <input type="text" id="localidad" class="text" />
  </div>
  <div class="field">
    <label for="telefono">Teléfono</label>
    <input type="text" id="telefono" class="text" />
  </div>
  <div class="field">
    <label for="tipo_trabajo">Tipo de trabajo</label>
    <select id="tipo_trabajo">
      <option value="">Seleccione...</option>
      <option value="Hombro">Hombro</option>
      <option value="Recapadora">Recapadora</option>
    </select>
  </div>
  <div class="form-actions">
    <button class="btn-primary" onclick="guardar()">Guardar</button>
    <button class="btn-ghost"   onclick="location.href='/admin/recapadora'">Cancelar</button>
  </div>
</div>
`;
%>
<%- include('../../layout', { body, user, currentPage }) %>
