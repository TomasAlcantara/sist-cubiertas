<%
const currentPage = 'admin';
const body = `
<div style="float:right;">
  <input type="button" value="Nueva Recapadora" onclick="location.href='/admin/recapadora/nuevo';" style="width:160px;"/>
</div>
<div class="clr" style="margin-bottom:10px;"></div>
<table>
  <thead><th>Nombre</th><th style="width:200px;">Editar</th></thead>
  ${recapadoras.map((r,i)=>`<tr class="${i%2===0?'light':'dark'}">
    <td>${r.nombre}</td>
    <td align="center">
      <a href="/admin/recapadora/editar?id=${r.id}">EDITAR</a> |
      <a style="cursor:pointer;" onclick="active(${r.id}, ${r.activo==1?0:1}, 'recapadora')">${r.activo==1?'BAJA':'ALTA'}</a>
    </td>
  </tr>`).join('')}
</table>
<br><a href="/admin">&laquo; Volver</a>
`;
%>
<%- include('../../layout', { body, user, currentPage }) %>
