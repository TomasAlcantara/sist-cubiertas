<%
const currentPage = 'admin';
const body = `
<div class="list-head">
  <h2>Almacenes</h2>
  <a href="/admin/almacen/nuevo" class="btn-nuevo">Nuevo Almacén</a>
</div>
<table>
  <thead><th>Nombre</th><th style="width:200px;">Editar</th></thead>
  ${almacenes.map((a,i)=>`<tr class="${i%2===0?'light':'dark'}">
    <td>${a.nombre}</td>
    <td align="center">
      <a href="/admin/almacen/editar?id=${a.id}">EDITAR</a> |
      <a style="cursor:pointer;" onclick="active(${a.id}, ${a.activo==1?0:1}, 'almacen')">${a.activo==1?'BAJA':'ALTA'}</a>
    </td>
  </tr>`).join('')}
</table>
<a href="/admin" class="list-back">&laquo; Volver</a>
`;
%>
<%- include('../../layout', { body, user, currentPage }) %>
