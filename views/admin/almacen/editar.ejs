<%
const currentPage = 'admin';
const body = `
<script>
function guardar() {
  $.ajax({ type:'POST', url:'/ajax/save_almacen',
    data:{
      id:            ${almacen.id},
      nombre:        document.getElementById('nombre').value,
      direccion:     document.getElementById('direccion').value,
      localidad:     document.getElementById('localidad').value,
      telefono:      document.getElementById('telefono').value,
      cargar_id:     document.getElementById('cargar_id').checked     ? '1':'0',
      cargar_remito: document.getElementById('cargar_remito').checked ? '1':'0'
    },
    success: function(data) { if(data) { alert(data); location.href='/admin/almacen'; } else alert('Error'); }
  });
}
</script>
<div style="width:340px; margin:0 auto;">
  <h3>Editar Almacén</h3>
  <p><strong>Nombre:</strong> <input type="text" id="nombre" value="${almacen.nombre||''}" style="float:right; width:190px;" /></p>
  <p><strong>Dirección:</strong> <input type="text" id="direccion" value="${almacen.direccion||''}" style="float:right; width:190px;" /></p>
  <p><strong>Localidad:</strong> <input type="text" id="localidad" value="${almacen.localidad||''}" style="float:right; width:190px;" /></p>
  <p><strong>Teléfono:</strong> <input type="text" id="telefono" value="${almacen.telefono||''}" style="float:right; width:190px;" /></p>
  <p>
    <strong>Cargar ID:</strong>
    <input type="checkbox" id="cargar_id" ${almacen.cargar_id?'checked':''} style="float:right; margin-top:4px;" />
  </p>
  <p>
    <strong>Cargar Remito:</strong>
    <input type="checkbox" id="cargar_remito" ${almacen.cargar_remito?'checked':''} style="float:right; margin-top:4px;" />
  </p>
  <div style="clear:both; margin-top:10px;">
    <input type="button" value="Guardar" style="float:left;" onclick="guardar();" />
    <input type="button" value="Cancelar" style="float:right;" onclick="location.href='/admin/almacen';" />
    <div class="clr"></div>
  </div>
</div>
`;
%>
<%- include('../../layout', { body, user, currentPage }) %>
