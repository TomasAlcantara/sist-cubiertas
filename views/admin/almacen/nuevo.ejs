<%
const currentPage = 'admin';
const body = `
<script>
function guardar() {
  var nombre = document.getElementById('nombre').value.trim();
  if (!nombre) { alert('Ingrese el nombre'); return; }
  $.ajax({ type:'POST', url:'/ajax/save_almacen',
    data:{
      nombre,
      direccion:     document.getElementById('direccion').value,
      localidad:     document.getElementById('localidad').value,
      telefono:      document.getElementById('telefono').value,
      cargar_id:     document.getElementById('cargar_id').checked     ? '1':'0',
      cargar_remito: document.getElementById('cargar_remito').checked ? '1':'0'
    },
    success: function(data) { if(data) { alert(data); location.href='/admin/almacen'; } else alert('Error'); }
  });
}
</script>
<div class="form-card">
  <div class="form-header"><h2>Nuevo Almacén</h2></div>
  <div class="field">
    <label for="nombre">Nombre</label>
    <input type="text" id="nombre" class="text" />
  </div>
  <div class="field">
    <label for="direccion">Dirección</label>
    <input type="text" id="direccion" class="text" />
  </div>
  <div class="field">
    <label for="localidad">Localidad</label>
    <input type="text" id="localidad" class="text" />
  </div>
  <div class="field">
    <label for="telefono">Teléfono</label>
    <input type="text" id="telefono" class="text" />
  </div>
  <div class="form-check">
    <input type="checkbox" id="cargar_id" />
    <label for="cargar_id">Cargar ID</label>
  </div>
  <div class="form-check">
    <input type="checkbox" id="cargar_remito" />
    <label for="cargar_remito">Cargar Remito</label>
  </div>
  <div class="form-actions">
    <button class="btn-primary" onclick="guardar()">Guardar</button>
    <button class="btn-ghost"   onclick="location.href='/admin/almacen'">Cancelar</button>
  </div>
</div>
`;
%>
<%- include('../../layout', { body, user, currentPage }) %>
