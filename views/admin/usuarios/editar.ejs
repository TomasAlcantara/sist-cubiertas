<%
const currentPage = 'admin';
const body = `
<script>
function guardar_datos() {
  $.ajax({ type:'POST', url:'/ajax/save_usuario',
    data: { id: ${usuario.id}, usuario: document.getElementById('usuario').value,
            password: document.getElementById('password').value,
            tipo: document.getElementById('tipo').value,
            nombre: document.getElementById('nombre').value,
            mail: document.getElementById('mail').value,
            avisa: document.getElementById('avisa').value,
            gomeria: document.getElementById('gomeria').value },
    success: function(data) { if(data) { alert(data); location.href='/admin/usuarios'; } else alert('Error'); }
  });
}
function diplay_me(obj) {
  var isGomeria = obj.value == 0;
  document.getElementById('pnombre').style.display  = isGomeria ? 'none' : '';
  document.getElementById('pavisa').style.display   = isGomeria ? 'none' : '';
  document.getElementById('pgomeria').style.display = isGomeria ? '' : 'none';
}
</script>
<div class="form-card">
  <div class="form-header"><h2>Editar Usuario</h2></div>
  <div class="field">
    <label for="usuario">Usuario</label>
    <input type="text" id="usuario" class="text" value="${e(usuario.usuario)}" />
  </div>
  <div class="field">
    <label for="password">Nueva contraseña</label>
    <input type="password" id="password" class="text" placeholder="Dejar vacío para no cambiar" />
  </div>
  <div class="field">
    <label for="tipo">Tipo</label>
    <select id="tipo" onchange="diplay_me(this)">
      <option value="0" ${usuario.tipo==0?'selected':''}>Gomeria</option>
      <option value="1" ${usuario.tipo==1?'selected':''}>Master Bus</option>
    </select>
  </div>
  <div id="pnombre" class="field" style="${usuario.tipo==1?'':'display:none;'}">
    <label for="nombre">Nombre</label>
    <input type="text" id="nombre" class="text" value="${e(usuario.nombre||'')}" />
  </div>
  <div class="field" id="pmail">
    <label for="mail">Mail</label>
    <input type="text" id="mail" class="text" value="${e(usuario.mail||'')}" />
  </div>
  <div id="pavisa" class="field" style="${usuario.tipo==1?'':'display:none;'}">
    <label for="avisa">Avisar por mail</label>
    <select id="avisa">
      <option value="0" ${usuario.avisa==0?'selected':''}>NO</option>
      <option value="1" ${usuario.avisa==1?'selected':''}>SI</option>
    </select>
  </div>
  <div id="pgomeria" class="field" style="${usuario.tipo==0?'':'display:none;'}">
    <label for="gomeria">Gomería</label>
    <select id="gomeria">
      <option value="0">Seleccione...</option>
      ${gomerias.map(g=>`<option value="${g.id}" ${g.id==usuario.gomeria_id?'selected':''}>${g.nombre}</option>`).join('')}
    </select>
  </div>
  <div class="form-actions">
    <button class="btn-primary" onclick="guardar_datos()">Guardar</button>
    <button class="btn-ghost"   onclick="location.href='/admin/usuarios'">Cancelar</button>
  </div>
</div>
`;
%>
<%- include('../../layout', { body, user, currentPage }) %>
