<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Master Bus — Ingresar</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800&family=Barlow:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<link href="/css/style.css" rel="stylesheet" />
<link rel="icon" type="image/png" href="/images/icon.png" />
<style>
  html, body { height: 100%; }

  .login-shell {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 460px;
  }

  /* ── Left: branding panel ── */
  .login-brand {
    background: var(--red);
    border-right: none;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 4rem 4.5rem;
    position: relative;
    overflow: hidden;
  }

  /* Background grid */
  .login-brand::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,0,0,0.1) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,0,0,0.1) 1px, transparent 1px);
    background-size: 44px 44px;
    pointer-events: none;
  }

  .login-brand-inner {
    position: relative;
    z-index: 1;
  }

  .login-brand-logo {
    height: 40px;
    width: auto;
    filter: brightness(0) invert(1);
    margin-bottom: 2.5rem;
    display: block;
  }

  .login-headline {
    font-family: var(--font-display);
    font-size: 4.5rem;
    font-weight: 800;
    line-height: 0.95;
    color: #fff;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    margin-bottom: 0;
  }

  .login-headline span {
    color: rgba(255,255,255,0.7);
    display: block;
  }

  .login-tagline {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    margin-top: 1.75rem;
    margin-bottom: 2.5rem;
  }

  .login-features {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .login-feature {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: rgba(255,255,255,0.65);
    letter-spacing: 0.04em;
  }

  .login-feature-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255,255,255,0.7);
    flex-shrink: 0;
  }

  /* ── Right: form panel ── */
  .login-form-panel {
    background: #ffffff;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 4rem 3.5rem;
    border-left: 1px solid var(--border);
  }

  .login-form-panel h2 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: 2.25rem;
  }

  .login-error {
    font-family: var(--font-mono);
    font-size: 11.5px;
    color: var(--red-bright);
    background: rgba(192, 57, 43, 0.1);
    border-left: 3px solid var(--red);
    padding: 9px 12px;
    border-radius: 0 var(--radius) var(--radius) 0;
    margin-bottom: 1.5rem;
    letter-spacing: 0.02em;
  }

  .login-field {
    margin-bottom: 1.25rem;
  }

  .login-field label {
    display: block;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 6px;
  }

  .login-field input {
    display: block;
    width: 100%;
    background: var(--bg-surface);
    border: 1px solid var(--border-strong);
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 14px;
    padding: 12px 14px;
    border-radius: var(--radius);
    transition: border-color 0.12s, box-shadow 0.12s;
  }

  .login-field input:focus {
    outline: none;
    border-color: var(--red);
    box-shadow: 0 0 0 3px rgba(192, 57, 43, 0.2);
  }

  .login-submit {
    margin-top: 1.75rem;
    width: 100%;
    background: var(--red);
    color: #fff;
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 14px;
    border: none;
    border-radius: var(--radius);
    cursor: pointer;
    transition: background 0.12s;
  }

  .login-submit:hover {
    background: var(--red-bright);
  }

  .login-copyright {
    margin-top: 3.5rem;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    color: var(--text-muted);
  }

  @media (max-width: 820px) {
    .login-shell { grid-template-columns: 1fr; }
    .login-brand { display: none; }
    .login-form-panel { padding: 2.5rem 2rem; }
  }
</style>
</head>
<body>
  <div class="login-shell">
    <div class="login-brand">
      <div class="login-brand-inner">
        <img src="/images/masterbus-logo.png" alt="Master Bus" class="login-brand-logo" />
        <div class="login-headline">
          Sistema<br>
          <span>Cubiertas</span>
        </div>
        <div class="login-tagline">Control de neumáticos &bull; Gestión de flota</div>
        <div class="login-features">
          <div class="login-feature">
            <div class="login-feature-dot"></div>
            Gestión de almacenes y stock
          </div>
          <div class="login-feature">
            <div class="login-feature-dot"></div>
            Seguimiento por kilómetro
          </div>
          <div class="login-feature">
            <div class="login-feature-dot"></div>
            Órdenes de trabajo integradas
          </div>
          <div class="login-feature">
            <div class="login-feature-dot"></div>
            Reportes de rendimiento
          </div>
          <div class="login-feature">
            <div class="login-feature-dot"></div>
            Control de recapadoras
          </div>
        </div>
      </div>
    </div>

    <div class="login-form-panel">
      <h2>Acceso al sistema</h2>

      <% if (error) { %>
        <div class="login-error"><%= error %></div>
      <% } %>

      <form method="post" action="/login">
        <div class="login-field">
          <label for="usr">Usuario</label>
          <input type="text" id="usr" name="usr" autocomplete="username" autofocus />
        </div>
        <div class="login-field">
          <label for="pass">Contraseña</label>
          <input type="password" id="pass" name="pass" autocomplete="current-password" />
        </div>
        <button type="submit" class="login-submit">Ingresar</button>
      </form>

      <div class="login-copyright">
        &copy; Master Bus S.A.
      </div>
    </div>
  </div>
</body>
</html>
