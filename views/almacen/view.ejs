<%
const estadoNombre = (est) => est == 1 ? 'Nueva' : est == 2 ? 'Usada' : 'Recapada';
const currentPage = 'inicio';
const body = `
<script>
function orderby(id) {
  var ob = ${filtros.orderby};
  if (id == ob) id += 10;
  var fuego = ${ej(filtros.fuego)};
  location.href = '?id=${almacen.id}&fuego=' + encodeURIComponent(fuego) + '&modelo=${filtros.modelo}&medida=${filtros.medida}&estado=${filtros.estado}&orderby=' + id;
}
function show_almacenes(cubierta_id) {
  document.getElementById('back').style.display = 'block';
  document.getElementById('almacenes').style.display = 'block';
  document.getElementById('cubierta_id').value = cubierta_id;
}
function close_almacenes() {
  document.getElementById('back').style.display = 'none';
  document.getElementById('almacenes').style.display = 'none';
}
function mover_cubierta(almacen) {
  $.ajax({ type:'POST', url:'/ajax/mover_cubierta', data:{ cubierta: document.getElementById('cubierta_id').value, almacen: almacen }, success: function(){ location.reload(); } });
}
function cambiar_estado(id, estadoActual) {
  var opts = ['', 'Nueva', 'Usada', 'Recapada'];
  var msg = 'Estado actual: ' + opts[estadoActual] + '\\nElegir nuevo estado:\\n1 = Nueva\\n2 = Usada\\n3 = Recapada';
  var val = prompt(msg);
  if (!val || val < 1 || val > 3) return;
  $.ajax({ type:'POST', url:'/ajax/nuevo_estado', data:{ r_id: id, estado: val }, success: function(){ location.reload(); } });
}
</script>

<div class="modal-overlay" id="back" onclick="close_almacenes();"></div>
<div class="modal-panel" id="almacenes" style="width:500px; padding:20px;">
  <button class="modal-close" onclick="close_almacenes();">&times;</button>
  <p style="font-family:var(--font-mono); font-size:10px; letter-spacing:0.12em; text-transform:uppercase; color:var(--text-muted); margin-bottom:12px;">Mover cubierta a:</p>
  <input type="hidden" id="cubierta_id" value="" />
  <div style="display:flex; flex-wrap:wrap; gap:6px; margin-bottom:14px;">
    ${almacenes.map(a => '<button class="btn-ghost" style="padding:7px 16px;" onclick="mover_cubierta(' + a.id + ')">' + a.nombre + '</button>').join('')}
  </div>
  <div style="text-align:right;">
    <button class="btn-ghost" onclick="close_almacenes()">Cancelar</button>
  </div>
</div>

<div class="list-head">
  <h2>${almacen.nombre}</h2>
  <a href="/cubiertas/nuevo" class="btn-nuevo">Nueva Rueda</a>
</div>

<form method="get" action="/almacen/view" class="list-filters">
  <input type="hidden" name="id" value="${almacen.id}" />
  <strong>Fuego:</strong>
  <input type="text" name="fuego" value="${e(filtros.fuego)}" maxlength="8" />
  <strong>Modelo:</strong>
  <select name="modelo">
    <option value="0">Todos</option>
    ${modelos.map(m => '<option value="' + m.id + '"' + (m.id == filtros.modelo ? ' selected' : '') + '>' + m.marca + ' ' + m.modelo + '</option>').join('')}
  </select>
  <strong>Medida:</strong>
  <select name="medida">
    <option value="0">Todas</option>
    ${medidas.map(m => '<option value="' + m.id + '"' + (m.id == filtros.medida ? ' selected' : '') + '>' + m.medida + '</option>').join('')}
  </select>
  <strong>Estado:</strong>
  <select name="estado">
    <option value="0">Todos</option>
    <option value="1"` + (filtros.estado==1?' selected':'') + `>Nueva</option>
    <option value="2"` + (filtros.estado==2?' selected':'') + `>Usada</option>
    <option value="3"` + (filtros.estado==3?' selected':'') + `>Recapada</option>
  </select>
  <button type="submit" class="btn-filter">Filtrar</button>
</form>

<table>
  <thead>
    <th onclick="orderby(1)" style="cursor:pointer;">Fuego</th>
    <th onclick="orderby(2)" style="cursor:pointer;">Modelo</th>
    <th onclick="orderby(3)" style="cursor:pointer;">Medida</th>
    <th onclick="orderby(4)" style="cursor:pointer;">Estado</th>
    <th onclick="orderby(5)" style="cursor:pointer;">Km</th>
    <th>Factura</th><th>Precio</th>
    <th style="width:160px;">Editar</th>
  </thead>
  ${cubiertas.length === 0 ? '<tr><td colspan="8" align="center">Sin cubiertas en este almacén</td></tr>' :
    cubiertas.map((c, i) => '<tr class="' + (i%2===0?'light':'dark') + '">'
      + '<td align="center">' + (c.fuego||'-') + '</td>'
      + '<td align="center">' + (c.marca||'') + ' ' + (c.modelo_nombre||'') + '</td>'
      + '<td align="center">' + (c.medida||'-') + '</td>'
      + '<td align="center">' + estadoNombre(c.estado) + '</td>'
      + '<td align="center">' + (c.km||0) + '</td>'
      + '<td align="center">' + (c.remito||'-') + '</td>'
      + '<td align="center">' + (c.precio != null ? '$' + parseFloat(c.precio).toFixed(2) : '-') + '</td>'
      + '<td align="center">'
        + '<a href="/cubiertas/editar?id=' + c.id + '">ALTA</a>'
        + ' | <a style="cursor:pointer;" onclick="show_almacenes(' + c.id + ')">MOVER</a>'
        + ' | <a style="cursor:pointer;" onclick="cambiar_estado(' + c.id + ',' + c.estado + ')">ESTADO</a>'
      + '</td>'
    + '</tr>').join('')
  }
</table>
<a href="/almacen" class="list-back">&laquo; Volver</a>
`;
%>
<%- include('../layout', { body, user, currentPage }) %>
